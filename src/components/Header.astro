---
import { t, localePath, type Locale } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { Menu, X, House, Info, LogIn, User, FileText, Search, Bookmark, Settings, Bell } from '@lucide/astro';

interface Props {
  locale: Locale;
  user?: { id: string; name?: string | null; email: string } | null;
}

const { locale, user } = Astro.props;
const i = t(locale);
---

<header class="site-header">
  <nav class="site-nav">
    <!-- Logo -->
    <a href={localePath(locale, '/')} class="site-logo" aria-label="Surbias home">
      <img src="/logo.png" alt="" width="28" height="28" class="logo-icon" loading="eager" />
      <span class="logo-text">SURBIAS</span>
    </a>

    <!-- Desktop nav -->
    <ul class="nav-links" role="list">
      <li>
        <a href={localePath(locale, '/')} class="nav-link">
          <House size={15} aria-hidden="true" />{i.nav.home}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/about')} class="nav-link">
          <Info size={15} aria-hidden="true" />{i.nav.about}
        </a>
      </li>
      {user ? (
        <>
          <li>
            <a href={localePath(locale, '/profile')} class="nav-link nav-link--subtle">
              <FileText size={15} aria-hidden="true" />{i.nav.profile}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/saved')} class="nav-link nav-link--subtle">
              <Bookmark size={15} aria-hidden="true" />{i.nav.saved}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/settings')} class="nav-link nav-link--subtle">
              <Settings size={15} aria-hidden="true" />{i.nav.settings}
            </a>
          </li>
          <li>
            <button class="nav-link nav-link--subtle nav-logout-btn" data-logout aria-label={i.nav.logout}>
              <User size={15} aria-hidden="true" />{i.nav.logout}
            </button>
          </li>
        </>
      ) : (
        <li>
          <a href={localePath(locale, '/login')} class="nav-link nav-link--subtle">
            <LogIn size={15} aria-hidden="true" />{i.nav.login}
          </a>
        </li>
      )}
      <li>
        <a href={localePath(locale, '/search')} class="nav-link">
          <Search size={15} aria-hidden="true" />{i.nav.search}
        </a>
      </li>
      <li class="nav-lang">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </li>
      {user && (
        <li class="nav-bell-wrap">
          <button class="nav-bell" id="nav-bell" aria-label="Notifications" type="button">
            <Bell size={16} aria-hidden="true" />
            <span class="nav-bell-badge" id="nav-bell-badge" hidden>0</span>
          </button>
          <div class="notif-dropdown" id="notif-dropdown" hidden role="dialog" aria-label="Notifications">
            <div class="notif-dropdown-header">
              <span>Notifications</span>
              <button type="button" data-notif-mark-read class="notif-mark-read">Mark all read</button>
            </div>
            <div class="notif-dropdown-list" id="notif-dropdown-list">
              <p class="notif-empty">Nothing yet. When someone reacts to or comments on your stories, you'll see it here.</p>
            </div>
          </div>
        </li>
      )}
      <li>
        <button class="nav-link nav-link--subtle" id="theme-toggle" aria-label="Toggle dark mode" style="background:none;border:none;cursor:pointer;font-family:inherit;">
          🌙
        </button>
      </li>
      <li>
        <a href={localePath(locale, '/support')} class="nav-coffee">☕ {i.common.footer_coffee}</a>
      </li>
    </ul>

    <!-- Mobile: right-side controls -->
    <div class="mobile-controls">
      <button
        class="mobile-nav-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Menu size={20} class="icon-menu" aria-hidden="true" />
        <X size={20} class="icon-close" aria-hidden="true" />
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      <li>
        <a href={localePath(locale, '/')} class="nav-link">
          <House size={15} aria-hidden="true" />{i.nav.home}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/about')} class="nav-link">
          <Info size={15} aria-hidden="true" />{i.nav.about}
        </a>
      </li>
      {user ? (
        <>
          <li>
            <a href={localePath(locale, '/profile')} class="nav-link">
              <FileText size={15} aria-hidden="true" />{i.nav.profile}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/saved')} class="nav-link">
              <Bookmark size={15} aria-hidden="true" />{i.nav.saved}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/settings')} class="nav-link">
              <Settings size={15} aria-hidden="true" />{i.nav.settings}
            </a>
          </li>
          <li>
            <button class="nav-link nav-logout-btn" data-logout aria-label={i.nav.logout}>
              <User size={15} aria-hidden="true" />{i.nav.logout}
            </button>
          </li>
        </>
      ) : (
        <li>
          <a href={localePath(locale, '/login')} class="nav-link">
            <LogIn size={15} aria-hidden="true" />{i.nav.login}
          </a>
        </li>
      )}
      <li>
        <a href={localePath(locale, '/search')} class="nav-link">
          <Search size={15} aria-hidden="true" />{i.nav.search}
        </a>
      </li>
      <li class="nav-lang">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </li>
      <li>
        <a href={localePath(locale, '/support')} class="nav-coffee">☕ {i.common.footer_coffee}</a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Notifications: poll every 60s, show badge with unread count
  (() => {
    const bell = document.getElementById('nav-bell');
    if (!bell) return; // not logged in
    const dropdown = document.getElementById('notif-dropdown')!;
    const list = document.getElementById('notif-dropdown-list')!;
    const badge = document.getElementById('nav-bell-badge')!;
    if (!dropdown || !list || !badge) return;

    function getLastSeen(): number {
      const v = parseInt(localStorage.getItem('surbias_notif_seen') || '0', 10);
      return v || Math.floor(Date.now() / 1000) - 30 * 86400;
    }
    function setLastSeen(ts: number) {
      try { localStorage.setItem('surbias_notif_seen', String(ts)); } catch (_) {}
    }
    function timeAgo(ts: number): string {
      const sec = Math.floor(Date.now() / 1000) - ts;
      if (sec < 60) return 'just now';
      if (sec < 3600) return Math.floor(sec / 60) + 'm';
      if (sec < 86400) return Math.floor(sec / 3600) + 'h';
      if (sec < 2592000) return Math.floor(sec / 86400) + 'd';
      return Math.floor(sec / 2592000) + 'mo';
    }
    function escapeHtml(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!));
    }

    interface NotifItem {
      type: 'reaction' | 'comment';
      id: string;
      reactionType?: string;
      body?: string;
      actor?: string;
      postId: string;
      postSlug: string | null;
      postTitle: string;
      createdAt: number;
    }

    function renderItem(it: NotifItem): string {
      const path = it.postSlug ? `/post/${it.postSlug}-${it.postId}` : `/post/${it.postId}`;
      const lang = document.documentElement.lang || 'en';
      const localePrefix = lang === 'en' ? '' : `/${lang}`;
      const url = localePrefix + path;
      const reactionEmojis: Record<string, string> = { metoo: '🤝', hug: '🫂', strength: '💪', respect: '🙇', solidarity: '✊' };
      if (it.type === 'reaction') {
        const emoji = reactionEmojis[it.reactionType || 'metoo'] || '💚';
        return `<a href="${url}" class="notif-item">
          <span class="notif-item-icon">${emoji}</span>
          <span class="notif-item-body">
            <span class="notif-item-title">Someone reacted to "${escapeHtml(it.postTitle)}"</span>
            <span class="notif-item-meta">${escapeHtml(it.reactionType || '')} · ${timeAgo(it.createdAt)}</span>
          </span>
        </a>`;
      }
      return `<a href="${url}" class="notif-item">
        <span class="notif-item-icon">💬</span>
        <span class="notif-item-body">
          <span class="notif-item-title">${escapeHtml(it.actor || 'Someone')} commented on "${escapeHtml(it.postTitle)}"</span>
          <span class="notif-item-meta">${escapeHtml(it.body || '')} · ${timeAgo(it.createdAt)}</span>
        </span>
      </a>`;
    }

    let latest: NotifItem[] = [];
    async function fetchNotifications() {
      try {
        const since = getLastSeen();
        const res = await fetch(`/api/notifications?since=${since}`);
        if (!res.ok) return;
        const data = await res.json() as { items: NotifItem[]; unread: number };
        latest = data.items || [];
        if (data.unread > 0) {
          badge.textContent = data.unread > 9 ? '9+' : String(data.unread);
          badge.hidden = false;
        } else {
          badge.hidden = true;
        }
      } catch (_) {}
    }

    bell.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = !dropdown.hidden;
      dropdown.hidden = isOpen;
      if (!isOpen) {
        list.innerHTML = latest.length
          ? latest.map(renderItem).join('')
          : '<p class="notif-empty">Nothing yet. When someone reacts to or comments on your stories, you\'ll see it here.</p>';
        // mark seen on open
        if (latest.length) setLastSeen(Math.floor(Date.now() / 1000));
        badge.hidden = true;
      }
    });
    document.addEventListener('click', (e) => {
      if (dropdown.hidden) return;
      const t = e.target as Element;
      if (!dropdown.contains(t) && !bell.contains(t)) dropdown.hidden = true;
    });
    document.querySelector('[data-notif-mark-read]')?.addEventListener('click', () => {
      setLastSeen(Math.floor(Date.now() / 1000));
      badge.hidden = true;
      window.showToast?.('All notifications marked as read.', 'success');
    });

    fetchNotifications();
    setInterval(fetchNotifications, 60_000);
  })();
</script>

<script>
  document.querySelectorAll('[data-logout]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      try {
        await fetch('/api/auth/sign-out', { method: 'POST' });
        window.location.href = '/';
      } catch (err) {
        console.error('Sign-out request failed:', err);
        window.location.href = '/';
      }
    });
  });
</script>

<script>
  const toggle = document.querySelector('.mobile-nav-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.setAttribute('aria-hidden', String(isOpen));
      menu.classList.toggle('is-open', !isOpen);
      toggle.classList.toggle('is-active', !isOpen);
    });

    // Close when a link inside the menu is clicked
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        menu.classList.remove('is-open');
        toggle.classList.remove('is-active');
      });
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--surbias-header-bg);
    border-bottom: 1px solid var(--surbias-border);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 100%;
    padding: 0 2.5rem;
    height: 60px;
    gap: 1rem;
  }

  /* Logo */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    display: block;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--surbias-text);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Desktop nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--surbias-text-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background-color 0.15s;
  }

  .nav-link:hover {
    color: var(--surbias-text);
    background-color: var(--surbias-warm-light);
  }

  .nav-link--subtle {
    color: var(--surbias-text-light);
    font-size: 0.85rem;
  }

  /* Logout button styled as a nav link */
  .nav-logout-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
  }

  /* CTA button */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 16px;
    background: var(--surbias-primary);
    color: #fff !important;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.15s, transform 0.1s;
  }

  .btn-cta:hover {
    background: var(--surbias-primary-hover);
    transform: translateY(-1px);
  }

  .btn-cta:active {
    transform: translateY(0);
  }

  .btn-cta--small {
    padding: 7px 12px;
    font-size: 0.8rem;
  }

  /* Language switcher item alignment */
  .nav-lang {
    display: flex;
    align-items: center;
  }

  /* Bell + notifications dropdown */
  .nav-bell-wrap {
    position: relative;
  }
  .nav-bell {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--surbias-text-muted);
    cursor: pointer;
    border-radius: 6px;
    position: relative;
    transition: color 0.15s, background 0.15s;
  }
  .nav-bell:hover { color: var(--surbias-text); background: var(--surbias-warm-light); }
  .nav-bell-badge {
    position: absolute;
    top: 1px;
    right: 1px;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background: var(--surbias-danger);
    color: #fff;
    border-radius: 9999px;
    font-size: 0.62rem;
    font-weight: 800;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
    border: 1.5px solid var(--surbias-header-bg);
  }
  .notif-dropdown {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    width: 360px;
    max-width: calc(100vw - 1rem);
    background: var(--surbias-card-bg);
    border: 1px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    z-index: 250;
    overflow: hidden;
  }
  .notif-dropdown-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--surbias-border);
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--surbias-text);
  }
  .notif-mark-read {
    background: transparent;
    border: none;
    color: var(--surbias-primary);
    font-size: 0.78rem;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
  }
  .notif-mark-read:hover { text-decoration: underline; }
  .notif-dropdown-list {
    max-height: 380px;
    overflow-y: auto;
  }
  .notif-empty {
    padding: 1.5rem 1rem;
    text-align: center;
    font-size: 0.82rem;
    color: var(--surbias-text-muted);
    line-height: 1.5;
    margin: 0;
  }
  .notif-item {
    display: flex;
    gap: 0.6rem;
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--surbias-border);
    text-decoration: none;
    color: var(--surbias-text);
    font-size: 0.85rem;
    line-height: 1.45;
    transition: background 0.12s;
  }
  .notif-item:last-child { border-bottom: none; }
  .notif-item:hover { background: var(--surbias-warm-light); }
  .notif-item-icon {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--surbias-warm-light);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
  }
  .notif-item-body { flex: 1; min-width: 0; }
  .notif-item-title {
    font-weight: 600;
    color: var(--surbias-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .notif-item-meta {
    font-size: 0.74rem;
    color: var(--surbias-text-muted);
    margin-top: 2px;
  }

  @media (max-width: 700px) {
    .notif-dropdown {
      position: fixed;
      top: 60px;
      right: 0.5rem;
      left: 0.5rem;
      width: auto;
    }
  }

  /* Buy us a coffee button — visible & inviting, but not loud */
  .nav-coffee {
    font-size: 0.8rem;
    padding: 6px 12px;
    background: linear-gradient(135deg, #fff8e1 0%, #ffe9a8 100%);
    color: #92600a;
    border: 1px solid #f0d080;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 700;
    white-space: nowrap;
    box-shadow: 0 1px 3px rgba(184,134,11,0.18);
    transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;
  }

  .nav-coffee:hover {
    background: linear-gradient(135deg, #ffefb3 0%, #ffdf85 100%);
    color: #6e4906;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(184,134,11,0.28);
  }

  /* Mobile controls (CTA + hamburger) */
  .mobile-controls {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }

  /* Hamburger button */
  .mobile-nav-toggle {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid var(--surbias-border);
    border-radius: 6px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    color: var(--surbias-text-muted);
  }

  .mobile-nav-toggle .icon-close {
    display: none;
  }

  .mobile-nav-toggle.is-active .icon-menu {
    display: none;
  }

  .mobile-nav-toggle.is-active .icon-close {
    display: block;
  }

  /* Mobile dropdown menu */
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--surbias-border);
    background-color: var(--surbias-header-bg);
  }

  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-menu .nav-link {
    display: block;
    padding: 10px 12px;
    font-size: 0.95rem;
  }

  .mobile-menu .nav-lang {
    padding: 8px 4px;
  }

  /* Responsive breakpoint */
  @media (max-width: 700px) {
    .nav-links {
      display: none;
    }

    .mobile-controls {
      display: flex;
    }
  }
</style>
