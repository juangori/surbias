---
import { t, localePath, type Locale } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { Menu, X, House, Info, LogIn, User, FileText, Search, Bookmark, Settings } from '@lucide/astro';

interface Props {
  locale: Locale;
  user?: { id: string; name?: string | null; email: string } | null;
}

const { locale, user } = Astro.props;
const i = t(locale);
---

<header class="site-header">
  <nav class="site-nav">
    <!-- Logo -->
    <a href={localePath(locale, '/')} class="site-logo" aria-label="Surbias home">
      <img src="/logo.png" alt="" width="28" height="28" class="logo-icon" loading="eager" />
      <span class="logo-text">SURBIAS</span>
    </a>

    <!-- Desktop nav -->
    <ul class="nav-links" role="list">
      <li>
        <a href={localePath(locale, '/')} class="nav-link">
          <House size={15} aria-hidden="true" />{i.nav.home}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/about')} class="nav-link">
          <Info size={15} aria-hidden="true" />{i.nav.about}
        </a>
      </li>
      {user ? (
        <>
          <li>
            <a href={localePath(locale, '/profile')} class="nav-link nav-link--subtle">
              <FileText size={15} aria-hidden="true" />{i.nav.profile}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/saved')} class="nav-link nav-link--subtle">
              <Bookmark size={15} aria-hidden="true" />{i.nav.saved}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/settings')} class="nav-link nav-link--subtle">
              <Settings size={15} aria-hidden="true" />{i.nav.settings}
            </a>
          </li>
          <li>
            <button class="nav-link nav-link--subtle nav-logout-btn" data-logout aria-label={i.nav.logout}>
              <User size={15} aria-hidden="true" />{i.nav.logout}
            </button>
          </li>
        </>
      ) : (
        <li>
          <a href={localePath(locale, '/login')} class="nav-link nav-link--subtle">
            <LogIn size={15} aria-hidden="true" />{i.nav.login}
          </a>
        </li>
      )}
      <li>
        <a href={localePath(locale, '/search')} class="nav-link">
          <Search size={15} aria-hidden="true" />{i.nav.search}
        </a>
      </li>
      <li class="nav-lang">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </li>
      <li>
        <button class="nav-link nav-link--subtle" id="theme-toggle" aria-label="Toggle dark mode" style="background:none;border:none;cursor:pointer;font-family:inherit;">
          🌙
        </button>
      </li>
      <li>
        <a href="https://ko-fi.com/surbias" target="_blank" rel="noopener" class="nav-coffee">☕ {i.common.footer_coffee}</a>
      </li>
    </ul>

    <!-- Mobile: right-side controls -->
    <div class="mobile-controls">
      <button
        class="mobile-nav-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Menu size={20} class="icon-menu" aria-hidden="true" />
        <X size={20} class="icon-close" aria-hidden="true" />
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      <li>
        <a href={localePath(locale, '/')} class="nav-link">
          <House size={15} aria-hidden="true" />{i.nav.home}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/about')} class="nav-link">
          <Info size={15} aria-hidden="true" />{i.nav.about}
        </a>
      </li>
      {user ? (
        <>
          <li>
            <a href={localePath(locale, '/profile')} class="nav-link">
              <FileText size={15} aria-hidden="true" />{i.nav.profile}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/saved')} class="nav-link">
              <Bookmark size={15} aria-hidden="true" />{i.nav.saved}
            </a>
          </li>
          <li>
            <a href={localePath(locale, '/settings')} class="nav-link">
              <Settings size={15} aria-hidden="true" />{i.nav.settings}
            </a>
          </li>
          <li>
            <button class="nav-link nav-logout-btn" data-logout aria-label={i.nav.logout}>
              <User size={15} aria-hidden="true" />{i.nav.logout}
            </button>
          </li>
        </>
      ) : (
        <li>
          <a href={localePath(locale, '/login')} class="nav-link">
            <LogIn size={15} aria-hidden="true" />{i.nav.login}
          </a>
        </li>
      )}
      <li>
        <a href={localePath(locale, '/search')} class="nav-link">
          <Search size={15} aria-hidden="true" />{i.nav.search}
        </a>
      </li>
      <li class="nav-lang">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </li>
      <li>
        <a href="https://ko-fi.com/surbias" target="_blank" rel="noopener" class="nav-coffee">☕ {i.common.footer_coffee}</a>
      </li>
    </ul>
  </div>
</header>

<script>
  document.querySelectorAll('[data-logout]').forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      try {
        await fetch('/api/auth/sign-out', { method: 'POST' });
        window.location.href = '/';
      } catch (err) {
        console.error('Sign-out request failed:', err);
        window.location.href = '/';
      }
    });
  });
</script>

<script>
  const toggle = document.querySelector('.mobile-nav-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.setAttribute('aria-hidden', String(isOpen));
      menu.classList.toggle('is-open', !isOpen);
      toggle.classList.toggle('is-active', !isOpen);
    });

    // Close when a link inside the menu is clicked
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        menu.classList.remove('is-open');
        toggle.classList.remove('is-active');
      });
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--surbias-header-bg);
    border-bottom: 1px solid var(--surbias-border);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 100%;
    padding: 0 2.5rem;
    height: 60px;
    gap: 1rem;
  }

  /* Logo */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-icon {
    display: block;
    flex-shrink: 0;
  }

  .logo-text {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--surbias-text);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Desktop nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--surbias-text-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background-color 0.15s;
  }

  .nav-link:hover {
    color: var(--surbias-text);
    background-color: var(--surbias-warm-light);
  }

  .nav-link--subtle {
    color: var(--surbias-text-light);
    font-size: 0.85rem;
  }

  /* Logout button styled as a nav link */
  .nav-logout-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
  }

  /* CTA button */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 16px;
    background: var(--surbias-primary);
    color: #fff !important;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.15s, transform 0.1s;
  }

  .btn-cta:hover {
    background: var(--surbias-primary-hover);
    transform: translateY(-1px);
  }

  .btn-cta:active {
    transform: translateY(0);
  }

  .btn-cta--small {
    padding: 7px 12px;
    font-size: 0.8rem;
  }

  /* Language switcher item alignment */
  .nav-lang {
    display: flex;
    align-items: center;
  }

  /* Buy us a coffee button */
  .nav-coffee {
    font-size: 0.8rem;
    padding: 5px 10px;
    background: var(--surbias-warm-light);
    color: var(--surbias-warm);
    border-radius: 6px;
    text-decoration: none;
    font-weight: 500;
    white-space: nowrap;
  }

  .nav-coffee:hover {
    background: var(--surbias-warm-tint);
  }

  /* Mobile controls (CTA + hamburger) */
  .mobile-controls {
    display: none;
    align-items: center;
    gap: 0.5rem;
  }

  /* Hamburger button */
  .mobile-nav-toggle {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid var(--surbias-border);
    border-radius: 6px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    color: var(--surbias-text-muted);
  }

  .mobile-nav-toggle .icon-close {
    display: none;
  }

  .mobile-nav-toggle.is-active .icon-menu {
    display: none;
  }

  .mobile-nav-toggle.is-active .icon-close {
    display: block;
  }

  /* Mobile dropdown menu */
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--surbias-border);
    background-color: var(--surbias-header-bg);
  }

  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem 1rem;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-menu .nav-link {
    display: block;
    padding: 10px 12px;
    font-size: 0.95rem;
  }

  .mobile-menu .nav-lang {
    padding: 8px 4px;
  }

  /* Responsive breakpoint */
  @media (max-width: 700px) {
    .nav-links {
      display: none;
    }

    .mobile-controls {
      display: flex;
    }
  }
</style>
