---
import { t, localePath, type Locale } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { Menu, X, House, Info, PenLine, LogIn } from '@lucide/astro';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<header class="site-header">
  <nav class="site-nav">
    <!-- Logo -->
    <a href={localePath(locale, '/')} class="site-logo" aria-label="Surbias home">
      <span class="logo-mark" aria-hidden="true">✕</span>
      <span class="logo-text">Surbias</span>
    </a>

    <!-- Desktop nav -->
    <ul class="nav-links" role="list">
      <li>
        <a href={localePath(locale, '/')} class="nav-link">
          <House size={15} aria-hidden="true" />{i.nav.home}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/about')} class="nav-link">
          <Info size={15} aria-hidden="true" />{i.nav.about}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/post/new')} class="btn-cta">
          <PenLine size={15} aria-hidden="true" />{i.nav.share}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/login')} class="nav-link nav-link--subtle">
          <LogIn size={15} aria-hidden="true" />{i.nav.login}
        </a>
      </li>
      <li class="nav-lang">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </li>
    </ul>

    <!-- Mobile: right-side controls -->
    <div class="mobile-controls">
      <a href={localePath(locale, '/post/new')} class="btn-cta btn-cta--small">
        {i.nav.share}
      </a>
      <button
        class="mobile-nav-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Menu size={20} class="icon-menu" aria-hidden="true" />
        <X size={20} class="icon-close" aria-hidden="true" />
      </button>
    </div>
  </nav>

  <!-- Mobile dropdown -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul role="list">
      <li>
        <a href={localePath(locale, '/')} class="nav-link">
          <House size={15} aria-hidden="true" />{i.nav.home}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/about')} class="nav-link">
          <Info size={15} aria-hidden="true" />{i.nav.about}
        </a>
      </li>
      <li>
        <a href={localePath(locale, '/login')} class="nav-link">
          <LogIn size={15} aria-hidden="true" />{i.nav.login}
        </a>
      </li>
      <li class="nav-lang">
        <LanguageSwitcher locale={locale} currentPath={Astro.url.pathname} />
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.querySelector('.mobile-nav-toggle') as HTMLButtonElement | null;
  const menu = document.getElementById('mobile-menu');

  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!isOpen));
      menu.setAttribute('aria-hidden', String(isOpen));
      menu.classList.toggle('is-open', !isOpen);
      toggle.classList.toggle('is-active', !isOpen);
    });

    // Close when a link inside the menu is clicked
    menu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        menu.classList.remove('is-open');
        toggle.classList.remove('is-active');
      });
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 var(--space-4);
    height: 60px;
    gap: var(--space-4);
  }

  /* Logo */
  .site-logo {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 700;
    line-height: 1;
  }

  .logo-text {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  /* Desktop nav links */
  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.15s, background-color 0.15s;
  }

  .nav-link:hover {
    color: var(--color-text-primary);
    background-color: var(--color-surface-raised);
  }

  .nav-link--subtle {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  /* CTA button */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 16px;
    background: var(--color-primary);
    color: #fff !important;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color 0.15s, transform 0.1s;
  }

  .btn-cta:hover {
    background: var(--color-primary-dark);
    transform: translateY(-1px);
  }

  .btn-cta:active {
    transform: translateY(0);
  }

  .btn-cta--small {
    padding: 7px 12px;
    font-size: 0.8rem;
  }

  /* Language switcher item alignment */
  .nav-lang {
    display: flex;
    align-items: center;
  }

  /* Mobile controls (CTA + hamburger) */
  .mobile-controls {
    display: none;
    align-items: center;
    gap: var(--space-2);
  }

  /* Hamburger button */
  .mobile-nav-toggle {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 36px;
    height: 36px;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    color: var(--color-text-secondary);
  }

  .mobile-nav-toggle .icon-close {
    display: none;
  }

  .mobile-nav-toggle.is-active .icon-menu {
    display: none;
  }

  .mobile-nav-toggle.is-active .icon-close {
    display: block;
  }

  /* Mobile dropdown menu */
  .mobile-menu {
    display: none;
    border-top: 1px solid var(--color-border);
    background-color: var(--color-surface);
  }

  .mobile-menu.is-open {
    display: block;
  }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: var(--space-2) var(--space-4);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-menu .nav-link {
    display: block;
    padding: 10px 12px;
    font-size: 0.95rem;
  }

  .mobile-menu .nav-lang {
    padding: 8px 4px;
  }

  /* Responsive breakpoint */
  @media (max-width: 700px) {
    .nav-links {
      display: none;
    }

    .mobile-controls {
      display: flex;
    }
  }
</style>
