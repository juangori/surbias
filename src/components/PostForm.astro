---
import { CATEGORIES } from '../db/schema';
import { t, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  turnstileSiteKey: string;
  error?: string;
}

const { locale, turnstileSiteKey, error } = Astro.props;
const i = t(locale);
---

<div class="post-form">
  <h1>{i.post.share_title}</h1>
  <p style="color: var(--surbias-text-muted); margin-bottom: 2rem;">{i.post.share_subtitle}</p>

  {error && (
    <div class="notice notice-error">
      {i.errors[error as keyof typeof i.errors] || i.errors.generic}
    </div>
  )}

  <form method="POST" action="/api/posts">
    <input type="hidden" name="locale" value={locale} />

    <!-- Honeypot -->
    <div class="ohnohoney">
      <label for="website">Website</label>
      <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <label for="title">
      {i.post.title_label}
      <input
        type="text"
        id="title"
        name="title"
        placeholder={i.post.title_placeholder}
        maxlength="150"
        required
      />
    </label>

    <label for="category">
      {i.post.category_label}
      <select id="category" name="category" required>
        {CATEGORIES.map((cat) => (
          <option value={cat}>
            {i.categories[cat as keyof typeof i.categories]}
          </option>
        ))}
      </select>
    </label>

    <label for="body">
      {i.post.body_label}
      <textarea
        id="body"
        name="body"
        placeholder={i.post.body_placeholder}
        maxlength="5000"
        required
      ></textarea>
    </label>

    <div class="form-footer">
      <label style="display: flex; align-items: center; gap: 0.5rem; margin: 0; cursor: pointer;">
        <input type="checkbox" name="is_anonymous" checked />
        {i.post.anonymous_label}
      </label>
      <button type="submit" class="btn-cta">{i.post.submit}</button>
    </div>

    <!-- Cloudflare Turnstile -->
    <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light" style="margin-top: 1rem;"></div>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </form>
</div>
