---
import { CATEGORIES } from '../db/schema';
import { t, type Locale } from '../i18n';
import { PenLine } from '@lucide/astro';

interface Props {
  locale: Locale;
  turnstileSiteKey: string;
  error?: string;
  inline?: boolean;
}

const { locale, turnstileSiteKey, error, inline = false } = Astro.props;
const i = t(locale);
---

<div class:list={['post-form', { 'post-form-inline': inline }]}>
  {!inline && (
    <div class="post-form-header">
      <PenLine size={36} class="post-form-icon" aria-hidden="true" />
      <h1>{i.post.share_title}</h1>
      <p>{i.post.share_subtitle}</p>
    </div>
  )}

  {error && (
    <div class="notice notice-error">
      {i.errors[error as keyof typeof i.errors] || i.errors.generic}
    </div>
  )}

  <form method="POST" action="/api/posts">
    <input type="hidden" name="locale" value={locale} />

    <!-- Honeypot -->
    <div class="ohnohoney">
      <label for={inline ? 'website-inline' : 'website'}>Website</label>
      <input type="text" id={inline ? 'website-inline' : 'website'} name="website" tabindex="-1" autocomplete="off" />
    </div>

    {inline ? (
      <!-- Inline compact layout -->
      <div class="inline-form-row">
        <input
          type="text"
          id="title-inline"
          name="title"
          placeholder={i.post.title_placeholder}
          maxlength="150"
          required
          class="inline-title"
        />
        <select id="category-inline" name="category" required class="inline-category">
          {CATEGORIES.map((cat) => (
            <option value={cat}>
              {i.categories[cat as keyof typeof i.categories]}
            </option>
          ))}
        </select>
      </div>
      <textarea
        id="body-inline"
        name="body"
        placeholder={i.post.body_placeholder}
        maxlength="5000"
        required
        class="inline-body"
        rows="3"
      ></textarea>
      <div class="form-footer">
        <label class="anonymous-toggle">
          <input type="checkbox" name="is_anonymous" checked />
          {i.post.anonymous_label}
        </label>
        <button type="submit" class="btn-cta">{i.post.submit}</button>
      </div>
    ) : (
      <!-- Full page layout -->
      <label for="title">
        {i.post.title_label}
        <input
          type="text"
          id="title"
          name="title"
          placeholder={i.post.title_placeholder}
          maxlength="150"
          required
        />
      </label>

      <label for="category">
        {i.post.category_label}
        <select id="category" name="category" required>
          {CATEGORIES.map((cat) => (
            <option value={cat}>
              {i.categories[cat as keyof typeof i.categories]}
            </option>
          ))}
        </select>
      </label>

      <label for="body">
        {i.post.body_label}
        <textarea
          id="body"
          name="body"
          placeholder={i.post.body_placeholder}
          maxlength="5000"
          required
        ></textarea>
      </label>

      <div class="form-footer">
        <label class="anonymous-toggle">
          <input type="checkbox" name="is_anonymous" checked />
          {i.post.anonymous_label}
        </label>
        <button type="submit" class="btn-cta">{i.post.submit}</button>
      </div>
    )}

    <!-- Cloudflare Turnstile -->
    <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="light" style="margin-top: 0.75rem;"></div>
    <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
  </form>
</div>

<style>
  .post-form-icon {
    display: block;
    margin-bottom: 0.5rem;
    color: var(--surbias-primary);
  }
</style>
