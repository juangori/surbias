---
import Base from '../../layouts/Base.astro';
import { getLocaleFromUrl, t } from '../../i18n';
import { getDb } from '../../db';
import { posts, users, comments, reactions } from '../../db/schema';
import { sql, eq } from 'drizzle-orm';
import { env } from 'cloudflare:workers';

const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);
const db = getDb(env.DB);

const totalPosts = (await db.select({ c: sql<number>`count(*)` }).from(posts).where(eq(posts.status, 'published')))[0]?.c || 0;
const totalUsers = (await db.select({ c: sql<number>`count(*)` }).from(users))[0]?.c || 0;
const totalComments = (await db.select({ c: sql<number>`count(*)` }).from(comments))[0]?.c || 0;
const totalReactions = (await db.select({ c: sql<number>`count(*)` }).from(reactions))[0]?.c || 0;

// Posts per category
const catStats = await db.select({ category: posts.category, count: sql<number>`count(*)` })
  .from(posts).where(eq(posts.status, 'published')).groupBy(posts.category);

// Posts per locale
const localeStats = await db.select({ locale: posts.locale, count: sql<number>`count(*)` })
  .from(posts).where(eq(posts.status, 'published')).groupBy(posts.locale);
---

<Base title="Stats">
  <div style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem;">
    <h1 style="margin-bottom: 2rem;">Community Stats</h1>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
      <div class="sidebar-card" style="text-align: center;">
        <p class="stat-number">{totalPosts}</p>
        <p class="stat-label">Stories</p>
      </div>
      <div class="sidebar-card" style="text-align: center;">
        <p class="stat-number">{totalUsers}</p>
        <p class="stat-label">Users</p>
      </div>
      <div class="sidebar-card" style="text-align: center;">
        <p class="stat-number">{totalComments}</p>
        <p class="stat-label">Comments</p>
      </div>
      <div class="sidebar-card" style="text-align: center;">
        <p class="stat-number">{totalReactions}</p>
        <p class="stat-label">Reactions</p>
      </div>
    </div>

    <h2>Stories by Category</h2>
    <div style="margin-bottom: 2rem;">
      {catStats.map(s => (
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
          <span style="width: 120px; font-size: 0.9rem; text-transform: capitalize;">{s.category}</span>
          <div style="flex: 1; background: var(--surbias-warm-light); border-radius: var(--radius-pill); height: 24px; overflow: hidden;">
            <div style={`width: ${Math.min(100, (s.count / Math.max(totalPosts, 1)) * 100)}%; background: var(--surbias-primary); height: 100%; border-radius: var(--radius-pill); min-width: 24px; display: flex; align-items: center; justify-content: flex-end; padding-right: 6px;`}>
              <span style="color: white; font-size: 0.75rem; font-weight: 600;">{s.count}</span>
            </div>
          </div>
        </div>
      ))}
    </div>

    <h2>Stories by Language</h2>
    <div>
      {localeStats.map(s => (
        <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
          <span style="width: 80px; font-size: 0.9rem; text-transform: uppercase;">{s.locale}</span>
          <div style="flex: 1; background: var(--surbias-warm-light); border-radius: var(--radius-pill); height: 24px; overflow: hidden;">
            <div style={`width: ${Math.min(100, (s.count / Math.max(totalPosts, 1)) * 100)}%; background: var(--surbias-accent); height: 100%; border-radius: var(--radius-pill); min-width: 24px; display: flex; align-items: center; justify-content: flex-end; padding-right: 6px;`}>
              <span style="color: white; font-size: 0.75rem; font-weight: 600;">{s.count}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Base>
