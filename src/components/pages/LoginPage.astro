---
import Base from '../../layouts/Base.astro';
import { getLocaleFromUrl, t } from '../../i18n';
import { Lock } from '@lucide/astro';

const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);
---

<Base title={i.auth.login_title}>
  <div class="auth-page">
    <div class="auth-header">
      <Lock size={40} class="auth-icon" aria-hidden="true" />
      <h1>{i.auth.login_title}</h1>
      <p>{i.auth.login_subtitle}</p>
    </div>

    <div class="auth-card">
      <!-- Google login -->
      <button class="btn-google" id="google-login">
        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844a4.14 4.14 0 01-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 009 18z" fill="#34A853"/>
          <path d="M3.964 10.71A5.41 5.41 0 013.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 000 9c0 1.452.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 00.957 4.958L3.964 7.29C4.672 5.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
        </svg>
        {i.auth.google_login}
      </button>

      <div class="auth-divider">{i.auth.or}</div>

      <!-- Email / password form -->
      <form id="auth-form">
        <label for="email">
          {i.auth.email}
          <input type="email" id="email" name="email" required />
        </label>
        <label for="password">
          {i.auth.password}
          <input type="password" id="password" name="password" required minlength="8" />
        </label>
        <button
          type="submit"
          class="btn-cta"
          style="width: 100%;"
          id="login-btn"
          data-login-text={i.auth.login_button}
          data-register-text={i.auth.register_button}
        >
          {i.auth.login_button}
        </button>
      </form>

      <div class="auth-toggle-row">
        <a
          href="#"
          id="toggle-mode"
          data-no-account={i.auth.no_account}
          data-has-account={i.auth.has_account}
        >
          {i.auth.no_account}
        </a>
        <a
          href="#"
          id="forgot-password"
          data-prompt={i.auth.enter_email_reset}
          data-success={i.auth.reset_sent}
        >
          {i.auth.forgot_password}
        </a>
      </div>
    </div>
  </div>
</Base>

<script>
  import { authClient } from '../../lib/auth-client';

  let isLogin = true;
  const form = document.getElementById('auth-form') as HTMLFormElement;
  const toggleBtn = document.getElementById('toggle-mode') as HTMLAnchorElement;
  const loginBtn = document.getElementById('login-btn') as HTMLButtonElement;
  const googleBtn = document.getElementById('google-login') as HTMLButtonElement;
  const forgotBtn = document.getElementById('forgot-password') as HTMLAnchorElement;

  toggleBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    isLogin = !isLogin;
    loginBtn.textContent = isLogin ? loginBtn.dataset.loginText! : loginBtn.dataset.registerText!;
    toggleBtn.textContent = isLogin ? toggleBtn.dataset.noAccount! : toggleBtn.dataset.hasAccount!;
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    const { error } = isLogin
      ? await authClient.signIn.email({ email, password })
      : await authClient.signUp.email({ email, password, name: email.split('@')[0] });

    if (error) {
      window.showToast(error.message || 'Something went wrong', 'error');
      return;
    }
    window.location.href = '/';
  });

  googleBtn?.addEventListener('click', async () => {
    await authClient.signIn.social({ provider: 'google', callbackURL: '/' });
  });

  forgotBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    const promptText = forgotBtn.dataset.prompt ?? 'Enter your email to reset your password';
    const successText = forgotBtn.dataset.success ?? 'Password reset link sent to your email.';
    const inputId = 'forgot-email-input';

    window.showModal({
      title: promptText,
      html: `<input id="${inputId}" type="email" placeholder="you@example.com" style="width:100%;padding:0.5rem 0.75rem;border:1.5px solid var(--surbias-border);border-radius:var(--radius-md);font-size:0.95rem;font-family:inherit;" />`,
      buttons: [
        { text: 'Cancel' },
        {
          text: 'Send reset link',
          class: 'btn-cta',
          onClick: async () => {
            const emailVal = (document.getElementById(inputId) as HTMLInputElement)?.value?.trim();
            if (!emailVal) return;
            try {
              await authClient.requestPasswordReset({ email: emailVal, redirectTo: '/login' });
              window.showToast(successText, 'success');
            } catch (err) {
              window.showToast('Error: ' + (err as Error).message, 'error');
            }
          },
        },
      ],
    });
  });
</script>

<style>
  .auth-icon {
    display: block;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
  }
</style>
