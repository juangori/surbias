---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import PostForm from '../../components/PostForm.astro';
import { getLocaleFromUrl, t, localePath } from '../../i18n';
import { createAuth } from '../../lib/auth';
import { getDb } from '../../db';
import { posts, reactions, categoryFollows, tags } from '../../db/schema';
import { desc, eq, and, sql } from 'drizzle-orm';
import { postWithAuthor } from '../../lib/post-query';
import { getWeeklyPrompt } from '../../lib/prompts';
import { env } from 'cloudflare:workers';

const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);
const db = getDb(env.DB);

// Auth check (optional — used for follow state)
let currentUserId: string | null = null;
let currentUserName: string | null = null;
try {
  const auth = createAuth(env);
  const session = await auth.api.getSession({ headers: Astro.request.headers });
  if (session?.user) {
    currentUserId = session.user.id;
    currentUserName = session.user.name || session.user.email || null;
  }
} catch (_) { /* ignore */ }
const userInitial = (currentUserName || '?').trim().charAt(0).toUpperCase() || '?';

// Fetch followed categories if logged in
let followedCategorySet = new Set<string>();
if (currentUserId) {
  const follows = await db
    .select({ category: categoryFollows.category })
    .from(categoryFollows)
    .where(eq(categoryFollows.userId, currentUserId));
  followedCategorySet = new Set(follows.map((f) => f.category));
}

const url = Astro.url;
const category = url.searchParams.get('category');
const sort = url.searchParams.get('sort') || 'recent';
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1'));
const perPage = 20;

// Build base conditions — filter by current locale
const conditions = [eq(posts.status, 'published'), eq(posts.locale, locale)];
if (category) conditions.push(eq(posts.category, category));

// For 'hot', last 7 days only
if (sort === 'hot') {
  const sevenDaysAgo = Math.floor((Date.now() - 7 * 24 * 60 * 60 * 1000) / 1000);
  conditions.push(sql`${posts.createdAt} >= ${sevenDaysAgo}`);
}

const where = conditions.length === 1 ? conditions[0] : and(...conditions);

let results;
if (sort === 'hot' || sort === 'popular') {
  const totalReactionsExpr = sql`(
    COALESCE(json_extract(${posts.reactionCounts}, '$.metoo'), 0) +
    COALESCE(json_extract(${posts.reactionCounts}, '$.hug'), 0) +
    COALESCE(json_extract(${posts.reactionCounts}, '$.strength'), 0) +
    COALESCE(json_extract(${posts.reactionCounts}, '$.respect'), 0) +
    COALESCE(json_extract(${posts.reactionCounts}, '$.solidarity'), 0)
  )`;
  results = await db.select(postWithAuthor).from(posts).where(where)
    .orderBy(sql`${totalReactionsExpr} DESC`, desc(posts.createdAt))
    .limit(perPage).offset((page - 1) * perPage);
} else {
  results = await db.select(postWithAuthor).from(posts).where(where)
    .orderBy(desc(posts.createdAt)).limit(perPage).offset((page - 1) * perPage);
}

const countResult = await db.select({ count: sql<number>`count(*)` }).from(posts).where(where);
const total = countResult[0]?.count || 0;
const totalPages = Math.ceil(total / perPage);

// Fetch counts per category for sidebar
const catCountRows = await db
  .select({ category: posts.category, count: sql<number>`count(*)` })
  .from(posts)
  .where(and(eq(posts.status, 'published'), eq(posts.locale, locale)))
  .groupBy(posts.category);

const categoryCounts: Record<string, number> = {};
for (const row of catCountRows) {
  categoryCounts[row.category] = row.count;
}

const metooResult = await db.select({ count: sql<number>`count(*)` }).from(reactions).where(eq(reactions.type, 'metoo'));
const totalMetoo = metooResult[0]?.count || 0;

const weeklyPrompt = getWeeklyPrompt(locale);

// Trending tags
const trendingTags = await db.select().from(tags).orderBy(desc(tags.count)).limit(10);

// Random story
const randomPost = await db.select({ id: posts.id }).from(posts)
  .where(eq(posts.status, 'published'))
  .orderBy(sql`RANDOM()`)
  .limit(1);
const randomPostId = randomPost[0]?.id;

// Pinned posts
const pinnedPosts = await db.select(postWithAuthor).from(posts)
  .where(and(eq(posts.status, 'published'), eq(posts.pinned, true), eq(posts.locale, locale)))
  .orderBy(desc(posts.createdAt))
  .limit(3);

const turnstileSiteKey = env.TURNSTILE_SITE_KEY || '';
const postError = url.searchParams.get('error') || undefined;

// Homepage ItemList JSON-LD — top recent stories, helps Google understand the feed
const homepageItemList = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: i.site.title + ' — ' + i.site.tagline,
  description: i.site.description,
  numberOfItems: results.length,
  itemListElement: results.slice(0, 10).map((p, idx) => {
    const path = p.slug ? `/post/${p.slug}-${p.id}` : `/post/${p.id}`;
    return {
      '@type': 'ListItem',
      position: idx + 1,
      url: `https://surbias.com${localePath(locale, path)}`,
      name: p.title,
    };
  }),
};

// Failure of the Week: most-reacted post from last 7 days
const sevenDaysAgo = Math.floor((Date.now() - 7 * 24 * 60 * 60 * 1000) / 1000);
const fotwCandidates = await db.select(postWithAuthor).from(posts)
  .where(and(
    eq(posts.status, 'published'),
    eq(posts.locale, locale),
    sql`${posts.createdAt} >= ${sevenDaysAgo}`
  ))
  .orderBy(desc(posts.createdAt))
  .limit(20);

let failureOfWeek = fotwCandidates[0] || null;
let maxReactions = 0;
for (const p of fotwCandidates) {
  const total = Object.values(JSON.parse(p.reactionCounts || '{}') as Record<string, number>).reduce((a, b) => a + b, 0);
  if (total > maxReactions) {
    maxReactions = total;
    failureOfWeek = p;
  }
}
---

<Base jsonLd={homepageItemList}>
  <!-- First-visit hero (hidden by default; revealed by JS for new visitors) -->
  <section class="welcome-hero" id="welcome-hero" aria-hidden="true">
    <button class="welcome-hero-close" aria-label="Dismiss intro" data-welcome-dismiss type="button">×</button>
    <div class="welcome-hero-emoji" aria-hidden="true">🫂</div>
    <h2 class="welcome-hero-title">{i.about.title}</h2>
    <p class="welcome-hero-text">{i.about.p3}</p>
    <div class="welcome-hero-actions">
      <a href={localePath(locale, '/post/new')} class="btn-cta">{i.common.share_cta}</a>
      <a href={localePath(locale, '/about')} class="welcome-hero-link">{i.nav.about} →</a>
    </div>
    <div class="welcome-hero-stats">
      <span><strong>{total}</strong> {i.common.stories}</span>
      <span aria-hidden="true">·</span>
      <span><strong>{totalMetoo}</strong> {i.common.metoos}</span>
      <span aria-hidden="true">·</span>
      <span>5 langs · 0 ads</span>
    </div>
  </section>

  <!-- Statement bar -->
  <div class="statement-bar">
    <p class="statement-text">{i.site.description}</p>
  </div>

  <!-- Sort tabs -->
  <div class="sort-tabs" role="tablist">
    <button class:list={['sort-tab', { active: sort === 'recent' }]} data-sort="recent" role="tab" aria-selected={sort === 'recent' ? 'true' : 'false'}>{i.common.sort_recent}</button>
    <button class:list={['sort-tab', { active: sort === 'hot' }]} data-sort="hot" role="tab" aria-selected={sort === 'hot' ? 'true' : 'false'}>{i.common.sort_hot}</button>
    <button class:list={['sort-tab', { active: sort === 'popular' }]} data-sort="popular" role="tab" aria-selected={sort === 'popular' ? 'true' : 'false'}>{i.common.sort_popular}</button>
  </div>

  <!-- Two-column layout -->
  <div class="home-content">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-card">
        <p class="sidebar-title">{i.common.categories_title}</p>
        <CategoryFilter
          locale={locale}
          activeCategory={category || undefined}
          sidebar={true}
          counts={categoryCounts}
          isLoggedIn={!!currentUserId}
          followedCategories={followedCategorySet}
        />
      </div>
    </aside>

    <!-- Feed -->
    <div class="feed">
      <!-- X-style composer (avatar + click-to-expand) / login CTA -->
      {currentUserId ? (
        <div class="composer-card" id="composer-card">
          <div class="composer-avatar" aria-hidden="true">{userInitial}</div>
          <div class="composer-content">
            <button class="composer-trigger" id="share-toggle" type="button" aria-expanded="false" aria-controls="inline-form-wrapper">
              {i.post.body_placeholder}
            </button>
            <div class="inline-form-section" id="inline-form-wrapper" style="display: none;">
              <PostForm locale={locale} turnstileSiteKey={turnstileSiteKey} error={postError} inline={true} />
            </div>
          </div>
        </div>
      ) : (
        <div class="share-toggle-section">
          <a href={localePath(locale, '/login')} class="share-toggle-btn share-toggle-btn--login">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" x2="3" y1="12" y2="12"/></svg>
            {i.auth.login_required}
          </a>
        </div>
      )}

      {failureOfWeek && maxReactions > 0 && page === 1 && !category && sort === 'recent' && (
        <article class="fotd-card" data-post-card data-post-id={failureOfWeek.id} data-post-title={failureOfWeek.title} data-post-url={`https://surbias.com${localePath(locale, failureOfWeek.slug ? `/post/${failureOfWeek.slug}-${failureOfWeek.id}` : `/post/${failureOfWeek.id}`)}`}>
          <p class="fotd-label">🏅 {i.common.failure_of_week}</p>
          <h2 class="fotd-title">
            <a href={localePath(locale, failureOfWeek.slug ? `/post/${failureOfWeek.slug}-${failureOfWeek.id}` : `/post/${failureOfWeek.id}`)}>
              {failureOfWeek.title}
            </a>
          </h2>
          <p class="fotd-meta">
            <span class="category-badge">{i.categories[failureOfWeek.category as keyof typeof i.categories] || failureOfWeek.category}</span>
            <span class="post-meta-sep" aria-hidden="true">•</span>
            <span>{failureOfWeek.isAnonymous ? '---' : (failureOfWeek.userName || '---')}</span>
            <span class="post-meta-sep" aria-hidden="true">•</span>
            <span>{maxReactions} reactions</span>
          </p>
        </article>
      )}

      {pinnedPosts.length > 0 && (
        <div class="pinned-section" style="margin-bottom: 1.5rem;">
          {pinnedPosts.map(p => (
            <div style="position: relative;">
              <span class="pinned-badge">📌 {i.common.pinned}</span>
              <PostCard locale={locale} post={p} />
            </div>
          ))}
        </div>
      )}

      <div
        id="posts-container"
        aria-live="polite"
        data-empty-text={i.common.empty}
        data-reaction-labels={JSON.stringify(i.reactions)}
        data-current-page={page}
        data-total-pages={totalPages}
      >
        <div class="posts-grid">
          {results.length === 0 ? (
            <div class="empty-state">
              <p class="empty-state-text">{category ? i.common.empty_category : i.common.empty}</p>
              {currentUserId && (
                <a href={localePath(locale, '/post/new')} class="btn-cta" style="font-size: 0.85rem;">
                  {i.common.share_cta}
                </a>
              )}
            </div>
          ) : (
            results.map((post) => <PostCard locale={locale} post={post} />)
          )}
        </div>

        <!-- Infinite scroll loader -->
        <div class="feed-loading" id="feed-loading">
          <div class="skeleton-card">
            <div class="skeleton-line short"></div>
            <div class="skeleton-line title"></div>
            <div class="skeleton-line full"></div>
            <div class="skeleton-line partial"></div>
          </div>
        </div>
        <div id="feed-sentinel" style="height: 1px;"></div>

        <!-- Pagination fallback (no JS) -->
        {totalPages > 1 && (
          <noscript>
            <div class="pagination">
              {page > 1 && (
                <a href={`${localePath(locale, '/')}?page=${page - 1}${category ? `&category=${category}` : ''}${sort !== 'recent' ? `&sort=${sort}` : ''}`} class="pagination-btn">
                  &larr; {i.common.previous}
                </a>
              )}
              {page < totalPages && (
                <a href={`${localePath(locale, '/')}?page=${page + 1}${category ? `&category=${category}` : ''}${sort !== 'recent' ? `&sort=${sort}` : ''}`} class="pagination-btn">
                  {i.common.next} &rarr;
                </a>
              )}
            </div>
          </noscript>
        )}
      </div>
    </div>

    <!-- Right sidebar -->
    <aside class="sidebar sidebar-right">
      <div class="sidebar-card">
        <p class="sidebar-title">{i.site.title}</p>
        <p class="sidebar-about">{i.common.about_sidebar}</p>
        <a href={localePath(locale, '/post/new')} class="btn-cta" style="width: 100%; text-align: center; display: block; margin-top: 0.75rem; font-size: 0.85rem;">{i.common.share_cta}</a>
      </div>
      <div class="sidebar-card" style="margin-top: 1rem;">
        <p class="sidebar-title">{i.common.stats}</p>
        <div class="sidebar-stats">
          <div class="stat-item"><span class="stat-number">{total}</span><span class="stat-label">{i.common.stories}</span></div>
          <div class="stat-item"><span class="stat-number">{totalMetoo}</span><span class="stat-label">{i.common.metoos}</span></div>
        </div>
      </div>
      {trendingTags.length > 0 && (
        <div class="sidebar-card" style="margin-top: 1rem;">
          <p class="sidebar-title">{i.common.trending_tags}</p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
            {trendingTags.map(tag => (
              <a href={localePath(locale, `/search?q=${tag.name}`)} class="tag-pill">#{tag.name}</a>
            ))}
          </div>
        </div>
      )}
      {randomPostId && (
        <div class="sidebar-card" style="margin-top: 1rem;">
          <a href={localePath(locale, `/post/${randomPostId}`)} class="btn-cta" style="width:100%;text-align:center;display:block;font-size:0.85rem;">
            🎲 {i.common.random_story}
          </a>
        </div>
      )}
      {failureOfWeek && maxReactions > 0 && (
        <div class="sidebar-card" style="margin-top: 1rem;">
          <p class="sidebar-title">🏅 {i.common.failure_of_week}</p>
          <a href={localePath(locale, `/post/${failureOfWeek.id}`)} style="text-decoration:none;color:var(--surbias-text);">
            <p style="font-weight:600;font-size:0.9rem;margin:0.5rem 0 0.25rem;">{failureOfWeek.title}</p>
            <p style="font-size:0.8rem;color:var(--surbias-text-muted);margin:0;">{maxReactions} reactions</p>
          </a>
        </div>
      )}
      <div class="sidebar-card" style="margin-top: 1rem;">
        <p class="sidebar-title">💡 {i.common.weekly_prompt}</p>
        <p class="sidebar-about" style="font-style: italic;">"{weeklyPrompt}"</p>
        <a href={localePath(locale, '/post/new')} class="btn-cta" style="width:100%;text-align:center;display:block;margin-top:0.75rem;font-size:0.85rem;">{i.common.share_cta}</a>
      </div>
      <div class="sidebar-card" style="margin-top: 1rem;">
        <p class="sidebar-title">{i.common.weekly_digest}</p>
        <p class="sidebar-about">{i.common.digest_description}</p>
        <form id="newsletter-form" data-locale={locale}>
          <input
            type="email"
            id="newsletter-email"
            placeholder="your@email.com"
            required
            class="newsletter-input"
            autocomplete="email"
          />
          <button type="submit" class="btn-cta newsletter-submit">
            {i.common.subscribe}
          </button>
        </form>
      </div>
    </aside>
  </div>
</Base>

<script>
  // First-visit welcome hero
  (() => {
    try {
      const visits = parseInt(localStorage.getItem('surbias_visits') || '0', 10);
      const dismissed = localStorage.getItem('surbias_welcome_dismissed') === '1';
      const hero = document.getElementById('welcome-hero');
      if (hero && visits <= 2 && !dismissed) {
        hero.classList.add('is-visible');
        hero.setAttribute('aria-hidden', 'false');
      }
      const close = hero?.querySelector('[data-welcome-dismiss]');
      close?.addEventListener('click', () => {
        hero?.classList.remove('is-visible');
        try { localStorage.setItem('surbias_welcome_dismissed', '1'); } catch (_) {}
      });
    } catch (_) {}
  })();
</script>

<script>
  (() => {
    const toggleBtn = document.getElementById('share-toggle');
    const formWrapper = document.getElementById('inline-form-wrapper');
    if (toggleBtn && formWrapper) {
      toggleBtn.addEventListener('click', () => {
        const isOpen = formWrapper.style.display !== 'none';
        formWrapper.style.display = isOpen ? 'none' : '';
        toggleBtn.classList.toggle('is-open', !isOpen);
        toggleBtn.setAttribute('aria-expanded', String(!isOpen));
        if (!isOpen) {
          const input = formWrapper.querySelector('input[name="title"]') as HTMLInputElement | null;
          input?.focus();
        }
      });
      if (new URLSearchParams(window.location.search).has('error')) {
        formWrapper.style.display = '';
        toggleBtn.classList.add('is-open');
      }
    }
  })();
</script>

<script>
  (() => {
    function getTimeLabels(): { min: string; hour: string; day: string; month: string } {
      // Read from the html lang attribute, fall back to English
      const lang = document.documentElement.lang || 'en';
      const timeLabels: Record<string, { min: string; hour: string; day: string; month: string }> = {
        en: { min: 'min', hour: 'h', day: 'd', month: 'mo' },
        es: { min: 'min', hour: 'h', day: 'd', month: 'me' },
        de: { min: 'Min', hour: 'Std', day: 'T', month: 'Mo' },
        fr: { min: 'min', hour: 'h', day: 'j', month: 'mo' },
        pt: { min: 'min', hour: 'h', day: 'd', month: 'me' },
      };
      return timeLabels[lang] || timeLabels['en'];
    }

    function timeAgo(createdAt: number): string {
      const { min, hour, day, month } = getTimeLabels();
      const seconds = Math.floor((Date.now() - createdAt) / 1000);
      if (seconds < 60) return `< 1 ${min}`;
      if (seconds < 3600) return `${Math.floor(seconds / 60)} ${min}`;
      if (seconds < 86400) return `${Math.floor(seconds / 3600)}${hour}`;
      if (seconds < 2592000) return `${Math.floor(seconds / 86400)}${day}`;
      return `${Math.floor(seconds / 2592000)}${month}`;
    }

    function getLocale(): string {
      return document.documentElement.lang || 'en';
    }

    function getLocalePath(path: string): string {
      const locale = getLocale();
      return locale === 'en' ? path : `/${locale}${path}`;
    }

    interface Post {
      id: string;
      slug?: string | null;
      title: string;
      body: string;
      category: string;
      isAnonymous: boolean | number;
      userName?: string | null;
      user_name?: string | null;
      reactionCounts: string;
      createdAt: number;
      commentCount?: number;
      comment_count?: number;
    }

    function getReactionLabels(): Record<string, string> {
      const container = document.getElementById('posts-container');
      if (container?.dataset.reactionLabels) {
        try {
          return JSON.parse(container.dataset.reactionLabels) as Record<string, string>;
        } catch (err) {
          console.error('Failed to parse reactionLabels:', err);
        }
      }
      return { metoo: 'Me too', hug: 'Hug', strength: 'Strength', respect: 'Respect', solidarity: 'Solidarity' };
    }

    function escHtml(s: string): string {
      return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }

    function renderCard(post: Post): string {
      const createdAtMs = post.createdAt * 1000;
      const reactions = JSON.parse(post.reactionCounts || '{}') as Record<string, number>;
      const bodyPreview = post.body.length > 220 ? post.body.slice(0, 220) + '…' : post.body;
      const categoryLabel =
        post.category.charAt(0).toUpperCase() + post.category.slice(1);
      const authorName = post.userName || post.user_name;
      const author = post.isAnonymous ? '---' : (authorName || '---');
      const slugPath = post.slug ? `/post/${post.slug}-${post.id}` : `/post/${post.id}`;
      const postPath = getLocalePath(slugPath);
      const fullUrl = window.location.origin + postPath;
      const comments = post.commentCount ?? post.comment_count ?? 0;
      const rl = getReactionLabels();
      const reactionsHtml = ['metoo','hug','strength','respect','solidarity'].map((rt) => `
        <button class="reaction-btn" type="button" data-reaction="${rt}" data-post-id="${post.id}" title="${escHtml(rl[rt])}" aria-label="${escHtml(rl[rt])}">
          <span class="reaction-label">${escHtml(rl[rt])}</span>
          <span class="reaction-count">${reactions[rt] || 0}</span>
        </button>`).join('');

      return `
        <article class="post-card" data-post-card data-post-id="${post.id}" data-post-title="${escHtml(post.title)}" data-post-url="${escHtml(fullUrl)}">
          <a href="${postPath}" class="post-card-link" aria-label="${escHtml(post.title)}"></a>
          <div class="post-card-accent"></div>
          <div class="post-meta">
            <span class="category-badge">${categoryLabel}</span>
            <span class="post-meta-sep">&bull;</span>
            <span>${escHtml(author)}</span>
            <span class="post-meta-sep">&bull;</span>
            <span>${timeAgo(createdAtMs)}</span>
          </div>
          <h3><a href="${postPath}">${escHtml(post.title)}</a></h3>
          <p class="post-body-preview">${escHtml(bodyPreview)}</p>
          <div class="post-card-footer">
            <div class="reaction-bar">${reactionsHtml}</div>
            <div class="post-card-actions">
              ${comments > 0 ? `<a href="${postPath}" class="comment-count-link" title="comments"><svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg><span>${comments}</span></a>` : ''}
              <button class="share-card-btn" data-share-card type="button" aria-label="Share" title="Share">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              </button>
              <button class="bookmark-btn" data-post-id="${post.id}" type="button" aria-label="Save" title="Save">
                <svg class="bookmark-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
              </button>
            </div>
          </div>
        </article>`;
    }

    function renderRow(posts: Post[]): string {
      return posts.map(renderCard).join('');
    }

    // Shared state
    let currentCategory = '';
    let currentSort = 'recent';
    let currentPage = 1;
    let totalPages = 1;
    let isLoadingMore = false;
    let reachedEnd = false;

    const initParams = new URLSearchParams(window.location.search);
    currentCategory = initParams.get('category') ?? '';
    currentSort = initParams.get('sort') ?? 'recent';

    const containerInit = document.getElementById('posts-container');
    if (containerInit) {
      currentPage = parseInt(containerInit.dataset.currentPage || '1', 10) || 1;
      totalPages = parseInt(containerInit.dataset.totalPages || '1', 10) || 1;
      reachedEnd = currentPage >= totalPages;
    }

    async function loadPosts(category: string, sort: string) {
      const locale = getLocale();
      const params = new URLSearchParams({ locale });
      if (category) params.set('category', category);
      if (sort && sort !== 'recent') params.set('sort', sort);

      const container = document.getElementById('posts-container');
      if (!container) return;

      container.style.opacity = '0.5';

      try {
        const res = await fetch(`/api/posts?${params}`);
        if (!res.ok) throw new Error('fetch failed');
        const data = await res.json() as { posts: Post[]; total: number; totalPages?: number; page?: number };
        const grid = container.querySelector('.posts-grid') as HTMLElement | null;
        if (grid) {
          if (data.posts.length) {
            grid.innerHTML = renderRow(data.posts);
          } else {
            const emptyText = container.dataset.emptyText || 'No stories yet.';
            grid.innerHTML = `<div class="empty-state"><p class="empty-state-text">${emptyText}</p></div>`;
          }
        }
        currentPage = data.page || 1;
        totalPages = data.totalPages || 1;
        reachedEnd = currentPage >= totalPages;
        const sentinel = document.getElementById('feed-sentinel');
        if (sentinel) sentinel.style.display = reachedEnd ? 'none' : '';
      } catch (err) {
        console.error('Posts fetch failed:', err);
      } finally {
        container.style.opacity = '';
      }
    }

    async function loadMore() {
      if (isLoadingMore || reachedEnd) return;
      isLoadingMore = true;
      const loading = document.getElementById('feed-loading');
      if (loading) loading.classList.add('is-active');

      const nextPage = currentPage + 1;
      const locale = getLocale();
      const params = new URLSearchParams({ locale, page: String(nextPage) });
      if (currentCategory) params.set('category', currentCategory);
      if (currentSort && currentSort !== 'recent') params.set('sort', currentSort);

      try {
        const res = await fetch(`/api/posts?${params}`);
        if (!res.ok) throw new Error('fetch failed');
        const data = await res.json() as { posts: Post[]; totalPages?: number; page?: number };
        const grid = document.querySelector('#posts-container .posts-grid') as HTMLElement | null;
        if (grid && data.posts.length) {
          grid.insertAdjacentHTML('beforeend', renderRow(data.posts));
        }
        currentPage = data.page || nextPage;
        totalPages = data.totalPages || totalPages;
        reachedEnd = currentPage >= totalPages || (data.posts || []).length === 0;
      } catch (err) {
        console.error('Load more failed:', err);
      } finally {
        if (loading) loading.classList.remove('is-active');
        isLoadingMore = false;
      }
    }

    // IntersectionObserver for infinite scroll
    const sentinel = document.getElementById('feed-sentinel');
    if (sentinel && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        if (entries.some((e) => e.isIntersecting)) loadMore();
      }, { rootMargin: '600px 0px' });
      io.observe(sentinel);
    }

    function buildUrl(category: string, sort: string): string {
      const basePath = getLocalePath('/');
      const params = new URLSearchParams();
      if (category) params.set('category', category);
      if (sort && sort !== 'recent') params.set('sort', sort);
      const qs = params.toString();
      return qs ? `${basePath}?${qs}` : basePath;
    }

    function setActivePill(category: string) {
      document.querySelectorAll('.sidebar-cat-item').forEach((el) => {
        const item = el as HTMLElement;
        const match = category ? item.dataset.category === category : item.dataset.category === '';
        item.classList.toggle('active', match);
      });
      document.querySelectorAll('.category-pill').forEach((el) => {
        const pill = el as HTMLElement;
        const match = category ? pill.dataset.category === category : pill.dataset.category === '';
        pill.classList.toggle('active', match);
      });
    }

    function setActiveSort(sort: string) {
      document.querySelectorAll('.sort-tab').forEach((el) => {
        const tab = el as HTMLElement;
        const match = tab.dataset.sort === sort;
        tab.classList.toggle('active', match);
        tab.setAttribute('aria-selected', match ? 'true' : 'false');
      });
    }

    // Category clicks
    document.addEventListener('click', (e) => {
      const target = (e.target as Element).closest('[data-category]');
      if (!target || (!target.classList.contains('sidebar-cat-item') && !target.classList.contains('category-pill'))) return;
      e.preventDefault();
      currentCategory = (target as HTMLElement).dataset.category ?? '';
      currentPage = 1;
      reachedEnd = false;
      setActivePill(currentCategory);
      const newUrl = buildUrl(currentCategory, currentSort);
      history.pushState({ category: currentCategory, sort: currentSort }, '', newUrl);
      loadPosts(currentCategory, currentSort);
    });

    // Sort tab clicks
    document.addEventListener('click', (e) => {
      const target = (e.target as Element).closest('.sort-tab');
      if (!target) return;
      e.preventDefault();
      currentSort = (target as HTMLElement).dataset.sort ?? 'recent';
      currentPage = 1;
      reachedEnd = false;
      setActiveSort(currentSort);
      const newUrl = buildUrl(currentCategory, currentSort);
      history.pushState({ category: currentCategory, sort: currentSort }, '', newUrl);
      loadPosts(currentCategory, currentSort);
    });

    // Back/forward
    window.addEventListener('popstate', (e) => {
      const state = e.state as { category?: string; sort?: string } | null;
      currentCategory = state?.category ?? '';
      currentSort = state?.sort ?? 'recent';
      setActivePill(currentCategory);
      setActiveSort(currentSort);
      loadPosts(currentCategory, currentSort);
    });
  })();
</script>

<script>
  (() => {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;
      const email = emailInput?.value?.trim();
      if (!email) return;

      const locale = (form.dataset.locale as string) || 'en';
      const submitBtn = form.querySelector('.newsletter-submit') as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, locale }),
        });
        const data = await res.json() as { subscribed?: boolean; error?: string };
        if (data.subscribed) {
          const lang = document.documentElement.lang || 'en';
          const labels: Record<string, string> = {
            en: 'Subscribed!',
            es: '¡Suscripto!',
            de: 'Abonniert!',
            fr: 'Abonné!',
            pt: 'Inscrito!',
          };
          window.showToast(labels[lang] || 'Subscribed!', 'success');
          form.reset();
        } else {
          window.showToast(data.error || 'Something went wrong.', 'error');
        }
      } catch (_) {
        window.showToast('Something went wrong.', 'error');
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  })();
</script>

