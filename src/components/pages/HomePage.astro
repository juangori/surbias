---
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import PostForm from '../../components/PostForm.astro';
import { getLocaleFromUrl, t, localePath } from '../../i18n';
import { createAuth } from '../../lib/auth';
import { getDb } from '../../db';
import { posts, reactions, categoryFollows, tags } from '../../db/schema';
import { desc, eq, and, sql } from 'drizzle-orm';
import { getWeeklyPrompt } from '../../lib/prompts';
import { env } from 'cloudflare:workers';

const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);
const db = getDb(env.DB);

// Auth check (optional — used for follow state)
let currentUserId: string | null = null;
try {
  const auth = createAuth(env);
  const session = await auth.api.getSession({ headers: Astro.request.headers });
  if (session?.user) currentUserId = session.user.id;
} catch (_) { /* ignore */ }

// Fetch followed categories if logged in
let followedCategorySet = new Set<string>();
if (currentUserId) {
  const follows = await db
    .select({ category: categoryFollows.category })
    .from(categoryFollows)
    .where(eq(categoryFollows.userId, currentUserId));
  followedCategorySet = new Set(follows.map((f) => f.category));
}

const url = Astro.url;
const category = url.searchParams.get('category');
const sort = url.searchParams.get('sort') || 'recent';
const page = Math.max(1, parseInt(url.searchParams.get('page') || '1'));
const perPage = 20;

// Build base conditions — filter by current locale
const conditions = [eq(posts.status, 'published'), eq(posts.locale, locale)];
if (category) conditions.push(eq(posts.category, category));

// For 'hot', last 7 days only
if (sort === 'hot') {
  const sevenDaysAgo = Math.floor((Date.now() - 7 * 24 * 60 * 60 * 1000) / 1000);
  conditions.push(sql`${posts.createdAt} >= ${sevenDaysAgo}`);
}

const where = conditions.length === 1 ? conditions[0] : and(...conditions);

function totalReactions(reactionCounts: string): number {
  try {
    const obj = JSON.parse(reactionCounts || '{}') as Record<string, number>;
    return Object.values(obj).reduce((sum, v) => sum + (v || 0), 0);
  } catch (err) {
    console.error('Failed to parse reactionCounts:', err);
    return 0;
  }
}

let results;
if (sort === 'hot' || sort === 'popular') {
  const allRows = await db.select().from(posts).where(where).orderBy(desc(posts.createdAt)).limit(perPage * 5);
  allRows.sort((a, b) => totalReactions(b.reactionCounts) - totalReactions(a.reactionCounts));
  results = allRows.slice((page - 1) * perPage, page * perPage);
} else {
  results = await db.select().from(posts).where(where).orderBy(desc(posts.createdAt)).limit(perPage).offset((page - 1) * perPage);
}

const countResult = await db.select({ count: sql<number>`count(*)` }).from(posts).where(where);
const total = countResult[0]?.count || 0;
const totalPages = Math.ceil(total / perPage);

// Fetch counts per category for sidebar
const catCountRows = await db
  .select({ category: posts.category, count: sql<number>`count(*)` })
  .from(posts)
  .where(and(eq(posts.status, 'published'), eq(posts.locale, locale)))
  .groupBy(posts.category);

const categoryCounts: Record<string, number> = {};
for (const row of catCountRows) {
  categoryCounts[row.category] = row.count;
}

const metooResult = await db.select({ count: sql<number>`count(*)` }).from(reactions).where(eq(reactions.type, 'metoo'));
const totalMetoo = metooResult[0]?.count || 0;

const weeklyPrompt = getWeeklyPrompt(locale);

// Trending tags
const trendingTags = await db.select().from(tags).orderBy(desc(tags.count)).limit(10);

// Random story
const randomPost = await db.select({ id: posts.id }).from(posts)
  .where(eq(posts.status, 'published'))
  .orderBy(sql`RANDOM()`)
  .limit(1);
const randomPostId = randomPost[0]?.id;

// Pinned posts
const pinnedPosts = await db.select().from(posts)
  .where(and(eq(posts.status, 'published'), eq(posts.pinned, true), eq(posts.locale, locale)))
  .orderBy(desc(posts.createdAt))
  .limit(3);

const turnstileSiteKey = env.TURNSTILE_SITE_KEY || '';
const postError = url.searchParams.get('error') || undefined;

// Failure of the Week: most-reacted post from last 7 days
const sevenDaysAgo = Math.floor((Date.now() - 7 * 24 * 60 * 60 * 1000) / 1000);
const fotwCandidates = await db.select().from(posts)
  .where(and(
    eq(posts.status, 'published'),
    eq(posts.locale, locale),
    sql`${posts.createdAt} >= ${sevenDaysAgo}`
  ))
  .orderBy(desc(posts.createdAt))
  .limit(20);

let failureOfWeek = fotwCandidates[0] || null;
let maxReactions = 0;
for (const p of fotwCandidates) {
  const total = Object.values(JSON.parse(p.reactionCounts || '{}') as Record<string, number>).reduce((a, b) => a + b, 0);
  if (total > maxReactions) {
    maxReactions = total;
    failureOfWeek = p;
  }
}
---

<Base>
  <!-- Statement bar -->
  <div class="statement-bar">
    <p class="statement-text">{i.site.description}</p>
  </div>

  <!-- Sort tabs -->
  <div class="sort-tabs" role="tablist">
    <button class:list={['sort-tab', { active: sort === 'recent' }]} data-sort="recent" role="tab" aria-selected={sort === 'recent' ? 'true' : 'false'}>{i.common.sort_recent}</button>
    <button class:list={['sort-tab', { active: sort === 'hot' }]} data-sort="hot" role="tab" aria-selected={sort === 'hot' ? 'true' : 'false'}>{i.common.sort_hot}</button>
    <button class:list={['sort-tab', { active: sort === 'popular' }]} data-sort="popular" role="tab" aria-selected={sort === 'popular' ? 'true' : 'false'}>{i.common.sort_popular}</button>
  </div>

  <!-- Two-column layout -->
  <div class="home-content">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div class="sidebar-card">
        <p class="sidebar-title">{i.common.categories_title}</p>
        <CategoryFilter
          locale={locale}
          activeCategory={category || undefined}
          sidebar={true}
          counts={categoryCounts}
          isLoggedIn={!!currentUserId}
          followedCategories={followedCategorySet}
        />
      </div>
    </aside>

    <!-- Feed -->
    <div class="feed">
      <!-- Inline post form -->
      <div class="inline-form-section">
        <PostForm locale={locale} turnstileSiteKey={turnstileSiteKey} error={postError} inline={true} />
      </div>

      {pinnedPosts.length > 0 && (
        <div class="pinned-section" style="margin-bottom: 1.5rem;">
          {pinnedPosts.map(p => (
            <div style="position: relative;">
              <span class="pinned-badge">📌 {i.common.pinned}</span>
              <PostCard locale={locale} post={p} />
            </div>
          ))}
        </div>
      )}

      <div id="posts-container" aria-live="polite" data-empty-text={i.common.empty} data-reaction-labels={JSON.stringify(i.reactions)}>
        <div class="posts-grid">
          {results.length === 0 ? (
            <div class="notice notice-info">{i.common.empty}</div>
          ) : (
            results.map((post) => <PostCard locale={locale} post={post} />)
          )}
        </div>

        <!-- Pagination -->
        {totalPages > 1 && (
          <div class="pagination">
            {page > 1 && (
              <a href={`${localePath(locale, '/')}?page=${page - 1}${category ? `&category=${category}` : ''}${sort !== 'recent' ? `&sort=${sort}` : ''}`}>
                &larr; {i.common.previous}
              </a>
            )}
            <span>{i.common.page} {page} / {totalPages}</span>
            {page < totalPages && (
              <a href={`${localePath(locale, '/')}?page=${page + 1}${category ? `&category=${category}` : ''}${sort !== 'recent' ? `&sort=${sort}` : ''}`}>
                {i.common.next} &rarr;
              </a>
            )}
          </div>
        )}
      </div>
    </div>

    <!-- Right sidebar -->
    <aside class="sidebar sidebar-right">
      <div class="sidebar-card">
        <p class="sidebar-title">{i.site.title}</p>
        <p class="sidebar-about">{i.common.about_sidebar}</p>
        <a href={localePath(locale, '/post/new')} class="btn-cta" style="width: 100%; text-align: center; display: block; margin-top: 0.75rem; font-size: 0.85rem;">{i.common.share_cta}</a>
      </div>
      <div class="sidebar-card" style="margin-top: 1rem;">
        <p class="sidebar-title">{i.common.stats}</p>
        <div class="sidebar-stats">
          <div class="stat-item"><span class="stat-number">{total}</span><span class="stat-label">{i.common.stories}</span></div>
          <div class="stat-item"><span class="stat-number">{totalMetoo}</span><span class="stat-label">{i.common.metoos}</span></div>
        </div>
      </div>
      {trendingTags.length > 0 && (
        <div class="sidebar-card" style="margin-top: 1rem;">
          <p class="sidebar-title">{i.common.trending_tags}</p>
          <div style="display: flex; flex-wrap: wrap; gap: 0.4rem;">
            {trendingTags.map(tag => (
              <a href={localePath(locale, `/search?q=${tag.name}`)} class="tag-pill">#{tag.name}</a>
            ))}
          </div>
        </div>
      )}
      {randomPostId && (
        <div class="sidebar-card" style="margin-top: 1rem;">
          <a href={localePath(locale, `/post/${randomPostId}`)} class="btn-cta" style="width:100%;text-align:center;display:block;font-size:0.85rem;">
            🎲 {i.common.random_story}
          </a>
        </div>
      )}
      {failureOfWeek && maxReactions > 0 && (
        <div class="sidebar-card" style="margin-top: 1rem;">
          <p class="sidebar-title">🏅 {i.common.failure_of_week}</p>
          <a href={localePath(locale, `/post/${failureOfWeek.id}`)} style="text-decoration:none;color:var(--surbias-text);">
            <p style="font-weight:600;font-size:0.9rem;margin:0.5rem 0 0.25rem;">{failureOfWeek.title}</p>
            <p style="font-size:0.8rem;color:var(--surbias-text-muted);margin:0;">{maxReactions} reactions</p>
          </a>
        </div>
      )}
      <div class="sidebar-card" style="margin-top: 1rem;">
        <p class="sidebar-title">💡 {i.common.weekly_prompt}</p>
        <p class="sidebar-about" style="font-style: italic;">"{weeklyPrompt}"</p>
        <a href={localePath(locale, '/post/new')} class="btn-cta" style="width:100%;text-align:center;display:block;margin-top:0.75rem;font-size:0.85rem;">{i.common.share_cta}</a>
      </div>
      <div class="sidebar-card" style="margin-top: 1rem;">
        <p class="sidebar-title">{i.common.weekly_digest}</p>
        <p class="sidebar-about">{i.common.digest_description}</p>
        <form id="newsletter-form" data-locale={locale}>
          <input
            type="email"
            id="newsletter-email"
            placeholder="your@email.com"
            required
            class="newsletter-input"
            autocomplete="email"
          />
          <button type="submit" class="btn-cta newsletter-submit">
            {i.common.subscribe}
          </button>
        </form>
      </div>
    </aside>
  </div>
</Base>

<script>
  (() => {
    function getTimeLabels(): { min: string; hour: string; day: string; month: string } {
      // Read from the html lang attribute, fall back to English
      const lang = document.documentElement.lang || 'en';
      const timeLabels: Record<string, { min: string; hour: string; day: string; month: string }> = {
        en: { min: 'min', hour: 'h', day: 'd', month: 'mo' },
        es: { min: 'min', hour: 'h', day: 'd', month: 'me' },
        de: { min: 'Min', hour: 'Std', day: 'T', month: 'Mo' },
        fr: { min: 'min', hour: 'h', day: 'j', month: 'mo' },
        pt: { min: 'min', hour: 'h', day: 'd', month: 'me' },
      };
      return timeLabels[lang] || timeLabels['en'];
    }

    function timeAgo(createdAt: number): string {
      const { min, hour, day, month } = getTimeLabels();
      const seconds = Math.floor((Date.now() - createdAt) / 1000);
      if (seconds < 60) return `< 1 ${min}`;
      if (seconds < 3600) return `${Math.floor(seconds / 60)} ${min}`;
      if (seconds < 86400) return `${Math.floor(seconds / 3600)}${hour}`;
      if (seconds < 2592000) return `${Math.floor(seconds / 86400)}${day}`;
      return `${Math.floor(seconds / 2592000)}${month}`;
    }

    function getLocale(): string {
      return document.documentElement.lang || 'en';
    }

    function getLocalePath(path: string): string {
      const locale = getLocale();
      return locale === 'en' ? path : `/${locale}${path}`;
    }

    interface Post {
      id: string;
      title: string;
      body: string;
      category: string;
      isAnonymous: boolean | number;
      userName?: string | null;
      reactionCounts: string;
      createdAt: number;
    }

    function getReactionLabels(): Record<string, string> {
      const container = document.getElementById('posts-container');
      if (container?.dataset.reactionLabels) {
        try {
          return JSON.parse(container.dataset.reactionLabels) as Record<string, string>;
        } catch (err) {
          console.error('Failed to parse reactionLabels:', err);
        }
      }
      return { metoo: 'Me too', hug: 'Hug', strength: 'Strength', respect: 'Respect', solidarity: 'Solidarity' };
    }

    function getReadMoreLabel(): string {
      const lang = document.documentElement.lang || 'en';
      const labels: Record<string, string> = {
        en: 'Read more',
        es: 'Leer m\u00e1s',
        de: 'Weiterlesen',
        fr: 'Lire la suite',
        pt: 'Ler mais',
      };
      return labels[lang] || labels['en'];
    }

    function renderCard(post: Post): string {
      const createdAtMs = post.createdAt * 1000;
      const reactions = JSON.parse(post.reactionCounts || '{}') as Record<string, number>;
      const bodyPreview = post.body.length > 250 ? post.body.slice(0, 250) + '...' : post.body;
      const categoryLabel =
        post.category.charAt(0).toUpperCase() + post.category.slice(1);
      const author = post.isAnonymous ? '---' : (post.userName || '---');
      const postPath = getLocalePath(`/post/${post.id}`);
      const rl = getReactionLabels();
      const readMore = getReadMoreLabel();

      return `
        <article class="post-card">
          <div class="post-card-accent"></div>
          <div class="post-meta">
            <span class="category-badge">${categoryLabel}</span>
            <span class="post-meta-sep">&bull;</span>
            <span>${author}</span>
            <span class="post-meta-sep">&bull;</span>
            <span>${timeAgo(createdAtMs)}</span>
          </div>
          <h3><a href="${postPath}">${post.title}</a></h3>
          <p class="post-body-preview">${bodyPreview}</p>
          <div class="post-card-footer">
            <div class="reaction-bar">
              <span class="reaction-btn" title="${rl.metoo}">
                <span class="reaction-label">${rl.metoo}</span>
                <span class="reaction-count">${reactions.metoo || 0}</span>
              </span>
              <span class="reaction-btn" title="${rl.hug}">
                <span class="reaction-label">${rl.hug}</span>
                <span class="reaction-count">${reactions.hug || 0}</span>
              </span>
              <span class="reaction-btn" title="${rl.strength}">
                <span class="reaction-label">${rl.strength}</span>
                <span class="reaction-count">${reactions.strength || 0}</span>
              </span>
              <span class="reaction-btn" title="${rl.respect}">
                <span class="reaction-label">${rl.respect}</span>
                <span class="reaction-count">${reactions.respect || 0}</span>
              </span>
              <span class="reaction-btn" title="${rl.solidarity}">
                <span class="reaction-label">${rl.solidarity}</span>
                <span class="reaction-count">${reactions.solidarity || 0}</span>
              </span>
            </div>
            <a href="${postPath}" class="read-more-link">${readMore} &rarr;</a>
          </div>
        </article>`;
    }

    function renderGrid(data: { posts: Post[]; total: number }): string {
      if (!data.posts.length) {
        const container = document.getElementById('posts-container');
        const emptyText = container?.dataset.emptyText || 'No stories yet. Be the first to share.';
        return `<div class="notice notice-info">${emptyText}</div>`;
      }
      return `<div class="posts-grid">${data.posts.map(renderCard).join('')}</div>`;
    }

    // Shared state
    let currentCategory = '';
    let currentSort = 'recent';

    const initParams = new URLSearchParams(window.location.search);
    currentCategory = initParams.get('category') ?? '';
    currentSort = initParams.get('sort') ?? 'recent';

    async function loadPosts(category: string, sort: string) {
      const locale = getLocale();
      const params = new URLSearchParams({ locale });
      if (category) params.set('category', category);
      if (sort && sort !== 'recent') params.set('sort', sort);

      const container = document.getElementById('posts-container');
      if (!container) return;

      container.style.opacity = '0.5';

      try {
        const res = await fetch(`/api/posts?${params}`);
        if (!res.ok) throw new Error('fetch failed');
        const data = await res.json() as { posts: Post[]; total: number };
        container.innerHTML = renderGrid(data);
      } catch (err) {
        console.error('Posts fetch failed:', err);
        // leave current content
      } finally {
        container.style.opacity = '';
      }
    }

    function buildUrl(category: string, sort: string): string {
      const basePath = getLocalePath('/');
      const params = new URLSearchParams();
      if (category) params.set('category', category);
      if (sort && sort !== 'recent') params.set('sort', sort);
      const qs = params.toString();
      return qs ? `${basePath}?${qs}` : basePath;
    }

    function setActivePill(category: string) {
      document.querySelectorAll('.sidebar-cat-item').forEach((el) => {
        const item = el as HTMLElement;
        const match = category ? item.dataset.category === category : item.dataset.category === '';
        item.classList.toggle('active', match);
      });
      document.querySelectorAll('.category-pill').forEach((el) => {
        const pill = el as HTMLElement;
        const match = category ? pill.dataset.category === category : pill.dataset.category === '';
        pill.classList.toggle('active', match);
      });
    }

    function setActiveSort(sort: string) {
      document.querySelectorAll('.sort-tab').forEach((el) => {
        const tab = el as HTMLElement;
        const match = tab.dataset.sort === sort;
        tab.classList.toggle('active', match);
        tab.setAttribute('aria-selected', match ? 'true' : 'false');
      });
    }

    // Category clicks
    document.addEventListener('click', (e) => {
      const target = (e.target as Element).closest('[data-category]');
      if (!target || (!target.classList.contains('sidebar-cat-item') && !target.classList.contains('category-pill'))) return;
      e.preventDefault();
      currentCategory = (target as HTMLElement).dataset.category ?? '';
      setActivePill(currentCategory);
      const newUrl = buildUrl(currentCategory, currentSort);
      history.pushState({ category: currentCategory, sort: currentSort }, '', newUrl);
      loadPosts(currentCategory, currentSort);
    });

    // Sort tab clicks
    document.addEventListener('click', (e) => {
      const target = (e.target as Element).closest('.sort-tab');
      if (!target) return;
      e.preventDefault();
      currentSort = (target as HTMLElement).dataset.sort ?? 'recent';
      setActiveSort(currentSort);
      const newUrl = buildUrl(currentCategory, currentSort);
      history.pushState({ category: currentCategory, sort: currentSort }, '', newUrl);
      loadPosts(currentCategory, currentSort);
    });

    // Back/forward
    window.addEventListener('popstate', (e) => {
      const state = e.state as { category?: string; sort?: string } | null;
      currentCategory = state?.category ?? '';
      currentSort = state?.sort ?? 'recent';
      setActivePill(currentCategory);
      setActiveSort(currentSort);
      loadPosts(currentCategory, currentSort);
    });
  })();
</script>

<script>
  (() => {
    const form = document.getElementById('newsletter-form') as HTMLFormElement | null;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const emailInput = document.getElementById('newsletter-email') as HTMLInputElement | null;
      const email = emailInput?.value?.trim();
      if (!email) return;

      const locale = (form.dataset.locale as string) || 'en';
      const submitBtn = form.querySelector('.newsletter-submit') as HTMLButtonElement | null;
      if (submitBtn) submitBtn.disabled = true;

      try {
        const res = await fetch('/api/newsletter/subscribe', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, locale }),
        });
        const data = await res.json() as { subscribed?: boolean; error?: string };
        if (data.subscribed) {
          const lang = document.documentElement.lang || 'en';
          const labels: Record<string, string> = {
            en: 'Subscribed!',
            es: '¡Suscripto!',
            de: 'Abonniert!',
            fr: 'Abonné!',
            pt: 'Inscrito!',
          };
          window.showToast(labels[lang] || 'Subscribed!', 'success');
          form.reset();
        } else {
          window.showToast(data.error || 'Something went wrong.', 'error');
        }
      } catch (_) {
        window.showToast('Something went wrong.', 'error');
      } finally {
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  })();
</script>

<style>
  .pinned-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    background: var(--surbias-warm-light);
    color: var(--surbias-warm);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: var(--radius-pill);
    z-index: 3;
  }

  .newsletter-input {
    width: 100%;
    padding: 8px 10px;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-family: inherit;
    font-size: 0.875rem;
    background: var(--color-surface);
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
    box-sizing: border-box;
  }

  .newsletter-input:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 1px;
  }

  .newsletter-submit {
    width: 100%;
    text-align: center;
    font-size: 0.85rem;
    justify-content: center;
  }
</style>
