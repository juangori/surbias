---
import Base from '../../layouts/Base.astro';
import PostCard from '../PostCard.astro';
import { getLocaleFromUrl, t, localePath } from '../../i18n';
import { createAuth } from '../../lib/auth';
import { getDb } from '../../db';
import { posts, reactions, comments } from '../../db/schema';
import { eq, desc, and, sql } from 'drizzle-orm';
import { env } from 'cloudflare:workers';
import { User, FileText, Trash2 } from '@lucide/astro';
import { BADGES, computeBadges } from '../../lib/badges';

const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);

// Auth check
const auth = createAuth(env);
const session = await auth.api.getSession({ headers: Astro.request.headers });

if (!session?.user) {
  return Astro.redirect(localePath(locale, '/login'));
}

const db = getDb(env.DB);
const userPosts = await db
  .select()
  .from(posts)
  .where(eq(posts.userId, session.user.id))
  .orderBy(desc(posts.createdAt));

const memberSince = new Date(session.user.createdAt ?? Date.now());
const memberSinceFormatted = memberSince.toLocaleDateString(locale, {
  year: 'numeric',
  month: 'long',
});

// Count posts this month
const now = new Date();
const firstOfMonth = new Date(now.getFullYear(), now.getMonth(), 1);
const monthStart = Math.floor(firstOfMonth.getTime() / 1000);

const monthPosts = await db.select({ count: sql<number>`count(*)` }).from(posts)
  .where(and(
    eq(posts.userId, session.user.id),
    eq(posts.status, 'published'),
    sql`${posts.createdAt} >= ${monthStart}`
  ));
const postsThisMonth = monthPosts[0]?.count || 0;

// Reactions received on user's posts
const reactionsReceived = await db.select({ count: sql<number>`count(*)` }).from(reactions)
  .innerJoin(posts, eq(reactions.postId, posts.id))
  .where(eq(posts.userId, session.user.id));
const totalReactions = reactionsReceived[0]?.count || 0;

// Comments left by user
const commentCount = await db.select({ count: sql<number>`count(*)` }).from(comments)
  .where(eq(comments.userId, session.user.id));
const totalComments = commentCount[0]?.count || 0;

const earnedBadgeIds = computeBadges({
  postCount: userPosts.length,
  totalReactionsReceived: totalReactions,
  commentCount: totalComments,
});
const earnedBadges = BADGES.filter(b => earnedBadgeIds.includes(b.id));
---

<Base title={i.nav.profile}>
  <div class="profile-page">
    <!-- User info card -->
    <div class="profile-card">
      <div class="profile-avatar">
        <User size={36} aria-hidden="true" />
      </div>
      <div class="profile-info">
        <h1 class="profile-name">{session.user.name || session.user.email}</h1>
        <p class="profile-email">{session.user.email}</p>
        <p class="profile-since">
          {i.common.member_since}: <strong>{memberSinceFormatted}</strong>
        </p>
        <div class="stat-item" style="margin-top: 0.75rem;">
          <span class="stat-number">{postsThisMonth}</span>
          <span class="stat-label">{i.common.stories_this_month}</span>
        </div>
      </div>
    </div>

    {earnedBadges.length > 0 && (
      <div style="margin-top: 1.5rem;">
        <h3>{i.common.badges}</h3>
        <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 0.75rem;">
          {earnedBadges.map(badge => (
            <div class="badge-card" title={badge.description[locale] || badge.description.en}>
              <span style="font-size: 1.5rem;">{badge.icon}</span>
              <span style="font-size: 0.8rem; font-weight: 500;">{badge.name[locale] || badge.name.en}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- My Posts section -->
    <section class="profile-posts-section">
      <div class="profile-posts-header">
        <FileText size={18} aria-hidden="true" />
        <h2>{i.nav.profile}</h2>
        <span class="posts-count">{userPosts.length}</span>
      </div>

      {userPosts.length === 0 ? (
        <div class="profile-empty">
          <p>{i.common.no_posts_yet}</p>
          <a href={localePath(locale, '/new')} class="btn-cta">
            {i.common.share_cta}
          </a>
        </div>
      ) : (
        <div class="posts-grid">
          {userPosts.map((post) => (
            <PostCard locale={locale} post={post} />
          ))}
        </div>
      )}
    </section>

    <!-- Notification Preferences -->
    <div style="margin-top: 1.5rem;">
      <h3>Notification Preferences</h3>
      <p style="color: var(--surbias-text-muted); font-size: 0.85rem; margin-bottom: 1rem;">Email notifications coming soon. Configure your preferences here.</p>
      <div style="display: flex; flex-direction: column; gap: 0.5rem;">
        <label class="anonymous-toggle"><input type="checkbox" checked disabled class="toggle-checkbox" /><span class="toggle-label">When someone reacts to my post</span></label>
        <label class="anonymous-toggle"><input type="checkbox" checked disabled class="toggle-checkbox" /><span class="toggle-label">When someone comments on my post</span></label>
        <label class="anonymous-toggle"><input type="checkbox" checked disabled class="toggle-checkbox" /><span class="toggle-label">Weekly digest email</span></label>
      </div>
    </div>

    <!-- Danger zone -->
    <section class="danger-zone">
      <h3>{i.common.delete_account}</h3>
      <button class="btn-delete-account" id="delete-account-btn">
        <Trash2 size={15} aria-hidden="true" />
        {i.common.delete_account}
      </button>
    </section>
  </div>
</Base>

<script>
  document.getElementById('delete-account-btn')?.addEventListener('click', function() {
    window.showModal({
      title: 'Delete account?',
      html: '<p>This will permanently delete your account. Your posts will be anonymized. This action cannot be undone.</p>',
      buttons: [
        { text: 'Cancel', class: '' },
        { text: 'Delete my account', class: 'modal-btn-danger', onClick: async function() {
          var res = await fetch('/api/account/delete', { method: 'POST' });
          if (res.ok) {
            window.showToast('Account deleted.', 'success');
            setTimeout(function() { window.location.href = '/'; }, 1500);
          } else {
            window.showToast('Could not delete account. Please try again.', 'error');
          }
        }}
      ]
    });
  });
</script>

<style>
  .profile-page {
    max-width: 860px;
    margin: 0 auto;
    padding: var(--space-6) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  /* Profile card */
  .profile-card {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: var(--space-5) var(--space-6);
  }

  .profile-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-primary-light, #e8f4ff);
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .profile-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .profile-name {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
  }

  .profile-email {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .profile-since {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Posts section */
  .profile-posts-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .profile-posts-header {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-primary);
  }

  .profile-posts-header h2 {
    font-size: 1.1rem;
    font-weight: 600;
    margin: 0;
  }

  .posts-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    height: 24px;
    padding: 0 6px;
    background: var(--color-surface-raised);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
  }

  .profile-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-8);
    background: var(--color-surface-raised);
    border: 1px dashed var(--color-border);
    border-radius: 12px;
    color: var(--color-text-muted);
    text-align: center;
  }

  .posts-grid {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  /* Danger zone */
  .danger-zone {
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .danger-zone h3 {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .btn-delete-account {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-muted);
    cursor: pointer;
    align-self: flex-start;
    transition: border-color 0.15s, color 0.15s;
  }

  .btn-delete-account:hover {
    border-color: var(--surbias-danger, #dc2626);
    color: var(--surbias-danger, #dc2626);
  }

  /* CTA button (reuse global style fallback) */
  .btn-cta {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 8px 16px;
    background: var(--color-primary);
    color: #fff;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 0.15s;
  }

  .btn-cta:hover {
    background: var(--color-primary-dark);
  }

  @media (max-width: 600px) {
    .profile-card {
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-4);
    }
  }
</style>
