---
import Base from '../../layouts/Base.astro';
import ReactionBar from '../../components/ReactionBar.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { getLocaleFromUrl, t, timeAgo, localePath } from '../../i18n';
import { getDb } from '../../db';
import { posts } from '../../db/schema';
import { comments as commentsTable } from '../../db/schema';
import { eq, desc } from 'drizzle-orm';
import { env } from 'cloudflare:workers';

interface Props {
  postId: string;
}

const { postId } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);
const db = getDb(env.DB);

const result = await db.select().from(posts).where(eq(posts.id, postId));
const post = result[0];

if (!post) {
  return Astro.redirect(localePath(locale, '/'));
}

const postComments = await db.select().from(commentsTable)
  .where(eq(commentsTable.postId, postId))
  .orderBy(desc(commentsTable.createdAt))
  .limit(50);

const createdAt = post.createdAt instanceof Date ? post.createdAt : new Date(Number(post.createdAt) * 1000);
const reactionCounts = JSON.parse(post.reactionCounts || '{}') as Record<string, number>;
const categoryLabel = i.categories[post.category as keyof typeof i.categories] || post.category;
const isFlagged = post.status === 'flagged';
---

<Base title={post.title}>
  <!-- Back navigation -->
  <div style="margin-bottom: 1.5rem;">
    <a href={localePath(locale, '/')} class="back-nav">
      &larr; {i.nav.home}
    </a>
  </div>

  <div class="home-content">
    <aside class="sidebar">
      <div class="sidebar-card">
        <p class="sidebar-title">{i.common.categories_title}</p>
        <CategoryFilter locale={locale} sidebar={true} />
      </div>
    </aside>

    <div class="feed">
      {isFlagged && (
        <div class="flagged-notice">{i.moderation.flagged}</div>
      )}

      {!isFlagged && (
        <div class="post-detail-card">
          <!-- Metadata row -->
          <div class="post-meta" style="margin-bottom: 1.25rem;">
            <span class="category-badge">{categoryLabel}</span>
            <span class="post-meta-sep">&bull;</span>
            <span>{post.isAnonymous ? '---' : (post.userName || '---')}</span>
            <span class="post-meta-sep">&bull;</span>
            <span>{timeAgo(createdAt, locale)}</span>
          </div>

          <!-- Title -->
          <h1 class="post-detail-title">{post.title}</h1>

          <!-- Body -->
          <div class="post-detail-body">{post.body}</div>

          <!-- Reactions -->
          <ReactionBar locale={locale} postId={post.id} reactionCounts={reactionCounts} />

          <!-- Comments section -->
          <div class="comments-section">
            <h3 class="comments-title">{i.common.comments} ({postComments.length})</h3>

            <!-- Comment form -->
            <div class="comment-form-wrapper">
              <textarea id="comment-body" placeholder={i.common.write_comment} maxlength="2000" rows="2" class="comment-input"></textarea>
              <div class="comment-form-footer">
                <label class="anonymous-toggle">
                  <input type="checkbox" id="comment-anon" checked class="toggle-checkbox" />
                  <span class="toggle-label">{i.common.anonymous}</span>
                </label>
                <button id="submit-comment" class="btn-cta" style="padding: 0.5rem 1rem; font-size: 0.85rem;">{i.common.comment}</button>
              </div>
            </div>

            <!-- Comments list -->
            <div id="comments-list">
              {postComments.map((c) => {
                const cDate = c.createdAt instanceof Date ? c.createdAt : new Date(Number(c.createdAt) * 1000);
                return (
                  <div class="comment-card">
                    <div class="comment-meta">
                      <span>{c.isAnonymous ? i.common.anonymous : (c.authorName || i.common.anonymous)}</span>
                      <span class="post-meta-sep">&bull;</span>
                      <span>{timeAgo(cDate, locale)}</span>
                    </div>
                    <p class="comment-body">{c.body}</p>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Report -->
          <div class="post-detail-actions">
            <button class="report-btn">
              &#9872; {i.moderation.report}
            </button>
          </div>
        </div>
      )}
    </div>
  </div>
</Base>

<script is:inline define:vars={{ postId, anonymousLabel: i.common.anonymous, justNowLabel: `< 1 ${i.common.time_min}`, i18n: { report_success: i.moderation.report_success, report_duplicate: i.moderation.report_duplicate, report_reason: i.moderation.report_reason, spam: i.moderation.spam, offensive: i.moderation.offensive, harmful: i.moderation.harmful, other: i.moderation.other } }}>
  async function reportPost(id) {
    window.showModal({
      title: i18n.report_reason,
      html: '<select class="modal-select" id="report-reason"><option value="spam">' + i18n.spam + '</option><option value="offensive">' + i18n.offensive + '</option><option value="harmful">' + i18n.harmful + '</option><option value="other">' + i18n.other + '</option></select>',
      buttons: [
        { text: 'Cancel', class: '' },
        { text: 'Report', class: 'modal-btn-danger', onClick: async function() {
          var reason = document.getElementById('report-reason').value;
          try {
            var res = await fetch('/api/posts/' + id + '/flag', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ reason: reason }),
            });
            if (res.ok) window.showToast(i18n.report_success, 'success');
            else if (res.status === 409) window.showToast(i18n.report_duplicate, 'info');
            else window.showToast('Something went wrong.', 'error');
          } catch(e) { window.showToast('Something went wrong.', 'error'); }
        }}
      ]
    });
  }

  document.getElementById('submit-comment')?.addEventListener('click', async function() {
    const bodyEl = document.getElementById('comment-body');
    const anonEl = document.getElementById('comment-anon');
    const body = bodyEl.value.trim();
    if (!body || body.length < 2) return;

    try {
      const res = await fetch('/api/posts/' + postId + '/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body: body, isAnonymous: anonEl.checked }),
      });
      if (res.ok) {
        bodyEl.value = '';
        const list = document.getElementById('comments-list');
        const div = document.createElement('div');
        div.className = 'comment-card';

        const meta = document.createElement('div');
        meta.className = 'comment-meta';

        const nameSpan = document.createElement('span');
        nameSpan.textContent = anonymousLabel;

        const sep = document.createElement('span');
        sep.className = 'post-meta-sep';
        sep.setAttribute('aria-hidden', 'true');
        sep.textContent = '•';

        const timeSpan = document.createElement('span');
        timeSpan.textContent = justNowLabel;

        meta.append(nameSpan, sep, timeSpan);

        const bodyP = document.createElement('p');
        bodyP.className = 'comment-body';
        bodyP.textContent = body; // textContent prevents XSS

        div.append(meta, bodyP);
        list.prepend(div);
        window.showToast('Comment added!', 'success');
      } else {
        window.showToast('Could not post comment.', 'error');
      }
    } catch { window.showToast('Could not post comment.', 'error'); }
  });

  // Attach reportPost to report button
  document.querySelector('.report-btn')?.addEventListener('click', function() {
    reportPost(postId);
  });
</script>
