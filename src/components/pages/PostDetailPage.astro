---
import Base from '../../layouts/Base.astro';
import ReactionBar from '../../components/ReactionBar.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import PostCard from '../../components/PostCard.astro';
import { getLocaleFromUrl, t, timeAgo, localePath } from '../../i18n';
import { getDb } from '../../db';
import { posts, postTags, tags } from '../../db/schema';
import { comments as commentsTable } from '../../db/schema';
import { eq, desc, and, sql } from 'drizzle-orm';
import { env } from 'cloudflare:workers';
import { createAuth } from '../../lib/auth';

interface Props {
  postId: string;
}

const { postId } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);
const db = getDb(env.DB);

const result = await db.select().from(posts).where(eq(posts.id, postId));
const post = result[0];

if (!post) {
  return Astro.redirect(localePath(locale, '/'));
}

const postComments = await db.select().from(commentsTable)
  .where(eq(commentsTable.postId, postId))
  .orderBy(desc(commentsTable.createdAt))
  .limit(50);

const createdAt = post.createdAt instanceof Date ? post.createdAt : new Date(Number(post.createdAt) * 1000);
const reactionCounts = JSON.parse(post.reactionCounts || '{}') as Record<string, number>;
const categoryLabel = i.categories[post.category as keyof typeof i.categories] || post.category;
const isFlagged = post.status === 'flagged';

// Check if current user owns the post
let isOwner = false;
let isLoggedIn = false;
try {
  const auth = createAuth(env);
  const session = await auth.api.getSession({ headers: Astro.request.headers });
  if (session?.user) {
    isLoggedIn = true;
    if (session.user.id === post.userId) isOwner = true;
  }
} catch (err) {
  console.error('Session check failed:', err);
}

// Simple markdown-to-HTML converter (HTML is escaped first, so this is XSS-safe)
function simpleMarkdown(text: string): string {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>')
    .replace(/`(.+?)`/g, '<code>$1</code>')
    .replace(/\n/g, '<br/>');
}

// Tags for this post
const postTagRows = await db
  .select({ name: tags.name })
  .from(postTags)
  .innerJoin(tags, eq(postTags.tagId, tags.id))
  .where(eq(postTags.postId, postId));

// Related posts (same category, same locale, excluding this post)
const relatedPosts = await db
  .select()
  .from(posts)
  .where(
    and(
      eq(posts.status, 'published'),
      eq(posts.category, post.category),
      eq(posts.locale, locale),
      sql`${posts.id} != ${postId}`
    )
  )
  .orderBy(desc(posts.createdAt))
  .limit(3);

const postPath = post.slug ? `/post/${post.slug}-${post.id}` : `/post/${post.id}`;
const postFullUrl = `https://surbias.com${localePath(locale, postPath)}`;
---

<Base title={post.title} description={post.body.slice(0, 160) + '...'} ogImage={`https://surbias.com/api/og/${post.id}`}>
  <!-- Back navigation -->
  <div style="margin-bottom: 1.5rem;">
    <a href={localePath(locale, '/')} class="back-nav">
      &larr; {i.nav.home}
    </a>
  </div>

  <div class="home-content">
    <aside class="sidebar">
      <div class="sidebar-card">
        <p class="sidebar-title">{i.common.categories_title}</p>
        <CategoryFilter locale={locale} sidebar={true} />
      </div>
    </aside>

    <div class="feed">
      {isFlagged && (
        <div class="flagged-notice">{i.moderation.flagged}</div>
      )}

      {!isFlagged && (
        <div class="post-detail-card">
          <!-- Metadata row -->
          <div class="post-meta" style="margin-bottom: 1.25rem;">
            <span class="category-badge">{categoryLabel}</span>
            <span class="post-meta-sep">&bull;</span>
            <span>{post.isAnonymous ? '---' : (post.userName || '---')}</span>
            <span class="post-meta-sep">&bull;</span>
            <span>{timeAgo(createdAt, locale)}</span>
          </div>

          <!-- Title -->
          <h1 class="post-detail-title">{post.title}</h1>

          <!-- Body -->
          <div class="post-detail-body" set:html={simpleMarkdown(post.body)}></div>

          <!-- Tags -->
          {postTagRows.length > 0 && (
            <div class="post-tags" style="margin-top: 1rem; display: flex; gap: 0.4rem; flex-wrap: wrap;">
              {postTagRows.map(t => (
                <a href={localePath(locale, `/search?q=${t.name}`)} class="tag-pill">#{t.name}</a>
              ))}
            </div>
          )}

          <!-- Reactions -->
          <ReactionBar locale={locale} postId={post.id} reactionCounts={reactionCounts} />

          <!-- Share buttons -->
          <div class="share-buttons" style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}&url=${encodeURIComponent(postFullUrl)}`} target="_blank" rel="noopener" class="share-btn">Share on X</a>
            <a href={`https://wa.me/?text=${encodeURIComponent(post.title + ' - ' + postFullUrl)}`} target="_blank" rel="noopener" class="share-btn">WhatsApp</a>
            <a href={`https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(postFullUrl)}`} target="_blank" rel="noopener" class="share-btn">QR Code</a>
          </div>

          <!-- Embed code -->
          <details style="margin-top: 0.75rem;">
            <summary style="cursor: pointer; font-size: 0.8rem; color: var(--surbias-text-muted);">Embed this story</summary>
            <pre style="margin-top: 0.5rem; padding: 0.5rem; background: var(--surbias-warm-light); border-radius: var(--radius-md); font-size: 0.75rem; overflow-x: auto; white-space: pre-wrap;"><code>{`<iframe src="https://surbias.com/api/embed/${post.id}" width="100%" height="250" frameborder="0"></iframe>`}</code></pre>
          </details>

          <!-- Comments section -->
          <div class="comments-section">
            <h3 class="comments-title">{i.common.comments} ({postComments.length})</h3>

            <!-- Comment form -->
            {isLoggedIn ? (
              <div class="comment-form-wrapper">
                <textarea id="comment-body" placeholder={i.common.write_comment} maxlength="2000" rows="2" class="comment-input"></textarea>
                <div class="comment-form-footer">
                  <label class="anonymous-toggle">
                    <input type="checkbox" id="comment-anon" checked class="toggle-checkbox" />
                    <span class="toggle-label">{i.common.anonymous}</span>
                  </label>
                  <button id="submit-comment" class="btn-cta" style="padding: 0.5rem 1rem; font-size: 0.85rem;">{i.common.comment}</button>
                </div>
              </div>
            ) : (
              <div class="comment-login-cta">
                <a href={localePath(locale, '/login')} class="btn-cta" style="display: inline-flex; font-size: 0.85rem; padding: 0.5rem 1rem;">
                  {i.auth.login_required_comment}
                </a>
              </div>
            )}

            <!-- Comments list -->
            <div id="comments-list">
              {postComments.map((c) => {
                const cDate = c.createdAt instanceof Date ? c.createdAt : new Date(Number(c.createdAt) * 1000);
                return (
                  <div class="comment-card">
                    <div class="comment-meta">
                      <span>{c.isAnonymous ? i.common.anonymous : (c.authorName || i.common.anonymous)}</span>
                      <span class="post-meta-sep">&bull;</span>
                      <span>{timeAgo(cDate, locale)}</span>
                    </div>
                    <p class="comment-body">{c.body}</p>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Report + owner actions -->
          <div class="post-detail-actions">
            <button class="report-btn">
              &#9872; {i.moderation.report}
            </button>
            {isOwner && (
              <button class="btn-cta" style="background: var(--surbias-danger); font-size: 0.8rem; padding: 0.4rem 1rem;" id="delete-own-post">
                Delete my post
              </button>
            )}
          </div>

          <!-- Related posts -->
          {relatedPosts.length > 0 && (
            <div style="margin-top: 2rem;">
              <h3>{i.common.related_stories}</h3>
              <div class="posts-grid">
                {relatedPosts.map(p => <PostCard locale={locale} post={p} />)}
              </div>
            </div>
          )}
        </div>
      )}
    </div>
  </div>
</Base>

<script is:inline define:vars={{ postId, anonymousLabel: i.common.anonymous, justNowLabel: `< 1 ${i.common.time_min}`, i18n: { report_success: i.moderation.report_success, report_duplicate: i.moderation.report_duplicate, report_reason: i.moderation.report_reason, spam: i.moderation.spam, offensive: i.moderation.offensive, harmful: i.moderation.harmful, other: i.moderation.other }, POST_ID: post.id }}>
  async function reportPost(id) {
    window.showModal({
      title: i18n.report_reason,
      html: '<select class="modal-select" id="report-reason"><option value="spam">' + i18n.spam + '</option><option value="offensive">' + i18n.offensive + '</option><option value="harmful">' + i18n.harmful + '</option><option value="other">' + i18n.other + '</option></select>',
      buttons: [
        { text: 'Cancel', class: '' },
        { text: 'Report', class: 'modal-btn-danger', onClick: async function() {
          var reason = document.getElementById('report-reason').value;
          try {
            var res = await fetch('/api/posts/' + id + '/flag', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ reason: reason }),
            });
            if (res.ok) window.showToast(i18n.report_success, 'success');
            else if (res.status === 409) window.showToast(i18n.report_duplicate, 'info');
            else window.showToast('Something went wrong.', 'error');
          } catch(e) { window.showToast('Something went wrong.', 'error'); }
        }}
      ]
    });
  }

  document.getElementById('submit-comment')?.addEventListener('click', async function() {
    const bodyEl = document.getElementById('comment-body');
    const anonEl = document.getElementById('comment-anon');
    const body = bodyEl.value.trim();
    if (!body || body.length < 2) return;

    try {
      const res = await fetch('/api/posts/' + postId + '/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ body: body, isAnonymous: anonEl.checked }),
      });
      if (res.ok) {
        bodyEl.value = '';
        const list = document.getElementById('comments-list');
        const div = document.createElement('div');
        div.className = 'comment-card';

        const meta = document.createElement('div');
        meta.className = 'comment-meta';

        const nameSpan = document.createElement('span');
        nameSpan.textContent = anonymousLabel;

        const sep = document.createElement('span');
        sep.className = 'post-meta-sep';
        sep.setAttribute('aria-hidden', 'true');
        sep.textContent = '•';

        const timeSpan = document.createElement('span');
        timeSpan.textContent = justNowLabel;

        meta.append(nameSpan, sep, timeSpan);

        const bodyP = document.createElement('p');
        bodyP.className = 'comment-body';
        bodyP.textContent = body; // textContent prevents XSS

        div.append(meta, bodyP);
        list.prepend(div);
        window.showToast('Comment added!', 'success');
      } else {
        window.showToast('Could not post comment.', 'error');
      }
    } catch (e) { console.error('Comment post failed:', e); window.showToast('Could not post comment.', 'error'); }
  });

  // Poll for new comments every 30 seconds
  setInterval(async function() {
    try {
      const res = await fetch('/api/posts/' + postId + '/comments');
      if (!res.ok) return;
      const data = await res.json();
      const list = document.getElementById('comments-list');
      if (!list || !data.comments) return;
      // Only update if count changed
      if (data.comments.length !== list.children.length) {
        list.innerHTML = '';
        data.comments.forEach(function(c) {
          const div = document.createElement('div');
          div.className = 'comment-card';
          const meta = document.createElement('div');
          meta.className = 'comment-meta';
          const author = document.createElement('span');
          author.textContent = c.is_anonymous || c.isAnonymous ? anonymousLabel : (c.author_name || c.authorName || anonymousLabel);
          meta.appendChild(author);
          const sep = document.createElement('span');
          sep.className = 'post-meta-sep';
          sep.innerHTML = '&bull;';
          meta.appendChild(sep);
          const time = document.createElement('span');
          time.textContent = justNowLabel;
          meta.appendChild(time);
          div.appendChild(meta);
          const body = document.createElement('p');
          body.className = 'comment-body';
          body.textContent = c.body;
          div.appendChild(body);
          list.appendChild(div);
        });
      }
    } catch(e) { console.error('Comment poll failed:', e); }
  }, 30000);

  // Attach reportPost to report button
  document.querySelector('.report-btn')?.addEventListener('click', function() {
    reportPost(postId);
  });

  // Delete own post
  document.getElementById('delete-own-post')?.addEventListener('click', function() {
    window.showModal({
      title: 'Delete post?',
      html: '<p>This action cannot be undone.</p>',
      buttons: [
        { text: 'Cancel', class: '' },
        { text: 'Delete', class: 'modal-btn-danger', onClick: async function() {
          var res = await fetch('/api/posts/' + POST_ID + '/delete', { method: 'POST' });
          if (res.ok) { window.showToast('Post deleted.', 'success'); setTimeout(function() { window.location.href = '/'; }, 1000); }
          else window.showToast('Could not delete post.', 'error');
        }}
      ]
    });
  });
</script>
