---
import { t, localePath, timeAgo, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  post: {
    id: string;
    slug?: string | null;
    title: string;
    body: string;
    category: string;
    isAnonymous: boolean | number;
    userName?: string | null;
    reactionCounts: string;
    createdAt: Date | number;
    commentCount?: number;
  };
  bookmarked?: boolean;
}

const { locale, post, bookmarked = false } = Astro.props;
const i = t(locale);

const createdAt = post.createdAt instanceof Date ? post.createdAt : new Date(Number(post.createdAt) * 1000);
const reactions = JSON.parse(post.reactionCounts || '{}') as Record<string, number>;
const categoryLabel = i.categories[post.category as keyof typeof i.categories] || post.category;
const bodyPreview = post.body.length > 250 ? post.body.slice(0, 250) + '...' : post.body;
const postPath = post.slug ? `/post/${post.slug}-${post.id}` : `/post/${post.id}`;
---

<article class="post-card">
  <a href={localePath(locale, postPath)} class="post-card-link" aria-label={post.title}></a>
  <div class="post-card-accent"></div>

  <!-- Metadata -->
  <div class="post-meta">
    <span class="category-badge">{categoryLabel}</span>
    <span class="post-meta-sep">&bull;</span>
    <span>{post.isAnonymous ? '---' : (post.userName || '---')}</span>
    <span class="post-meta-sep">&bull;</span>
    <span>{timeAgo(createdAt, locale)}</span>
  </div>

  <!-- Title -->
  <h3>
    <a href={localePath(locale, postPath)}>{post.title}</a>
  </h3>

  <!-- Body preview -->
  <p class="post-body-preview">{bodyPreview}</p>

  <!-- Footer: reactions + bookmark + read more -->
  <div class="post-card-footer">
    <div class="reaction-bar">
      <span class="reaction-btn" title={i.reactions.metoo}>
        <span class="reaction-label">{i.reactions.metoo}</span>
        <span class="reaction-count">{reactions.metoo || 0}</span>
      </span>
      <span class="reaction-btn" title={i.reactions.hug}>
        <span class="reaction-label">{i.reactions.hug}</span>
        <span class="reaction-count">{reactions.hug || 0}</span>
      </span>
      <span class="reaction-btn" title={i.reactions.strength}>
        <span class="reaction-label">{i.reactions.strength}</span>
        <span class="reaction-count">{reactions.strength || 0}</span>
      </span>
      <span class="reaction-btn" title={i.reactions.respect}>
        <span class="reaction-label">{i.reactions.respect}</span>
        <span class="reaction-count">{reactions.respect || 0}</span>
      </span>
      <span class="reaction-btn" title={i.reactions.solidarity}>
        <span class="reaction-label">{i.reactions.solidarity}</span>
        <span class="reaction-count">{reactions.solidarity || 0}</span>
      </span>
    </div>
    <div class="post-card-actions">
      {(post.commentCount ?? 0) > 0 && (
        <a href={localePath(locale, postPath)} class="comment-count-link" title={i.common.comments}>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span>{post.commentCount}</span>
        </a>
      )}
      <button
        class:list={['bookmark-btn', { 'is-bookmarked': bookmarked }]}
        data-post-id={post.id}
        aria-label={bookmarked ? i.nav.saved : 'Save'}
        title={bookmarked ? i.nav.saved : 'Save'}
      >
        <svg class="bookmark-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill={bookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
        <span class="bookmark-label">{bookmarked ? i.nav.saved : 'Save'}</span>
      </button>
      <a href={localePath(locale, postPath)} class="read-more-link">
        {i.post.read_more} &rarr;
      </a>
    </div>
  </div>
</article>

<style>
  .post-card-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .comment-count-link {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-decoration: none;
    padding: 2px 4px;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .comment-count-link:hover {
    color: var(--color-primary);
  }

  .bookmark-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding: 2px 4px;
    border-radius: 4px;
    transition: color 0.15s;
    line-height: 1;
  }

  .bookmark-btn:hover {
    color: var(--color-primary);
  }

  .bookmark-btn.is-bookmarked {
    color: var(--color-primary);
  }
</style>
