---
import { t, localePath, timeAgo, type Locale } from '../i18n';
import { REACTION_TYPES } from '../db/schema';

interface Props {
  locale: Locale;
  post: {
    id: string;
    slug?: string | null;
    title: string;
    body: string;
    category: string;
    isAnonymous: boolean | number;
    userName?: string | null;
    reactionCounts: string;
    createdAt: Date | number;
    commentCount?: number;
  };
  bookmarked?: boolean;
}

const { locale, post, bookmarked = false } = Astro.props;
const i = t(locale);

const createdAt = post.createdAt instanceof Date ? post.createdAt : new Date(Number(post.createdAt) * 1000);
const reactions = JSON.parse(post.reactionCounts || '{}') as Record<string, number>;
const categoryLabel = i.categories[post.category as keyof typeof i.categories] || post.category;
const bodyPreview = post.body.length > 220 ? post.body.slice(0, 220) + '…' : post.body;
const postPath = post.slug ? `/post/${post.slug}-${post.id}` : `/post/${post.id}`;
const fullUrl = `https://surbias.com${localePath(locale, postPath)}`;
---

<article class="post-card" data-post-card data-post-id={post.id} data-post-title={post.title} data-post-url={fullUrl}>
  <a href={localePath(locale, postPath)} class="post-card-link" aria-label={post.title}></a>
  <div class="post-card-accent"></div>

  <!-- Metadata -->
  <div class="post-meta">
    <span class="category-badge">{categoryLabel}</span>
    <span class="post-meta-sep" aria-hidden="true">&bull;</span>
    <span>{post.isAnonymous ? '---' : (post.userName || '---')}</span>
    <span class="post-meta-sep" aria-hidden="true">&bull;</span>
    <span>{timeAgo(createdAt, locale)}</span>
  </div>

  <!-- Title -->
  <h3>
    <a href={localePath(locale, postPath)}>{post.title}</a>
  </h3>

  <!-- Body preview -->
  <p class="post-body-preview">{bodyPreview}</p>

  <!-- Footer: reactions + bookmark + share + read more -->
  <div class="post-card-footer">
    <div class="reaction-bar">
      {REACTION_TYPES.map((rType) => (
        <button
          class="reaction-btn"
          data-reaction={rType}
          data-post-id={post.id}
          title={i.reactions[rType as keyof typeof i.reactions]}
          aria-label={i.reactions[rType as keyof typeof i.reactions]}
          type="button"
        >
          <span class="reaction-label">{i.reactions[rType as keyof typeof i.reactions]}</span>
          <span class="reaction-count">{reactions[rType] || 0}</span>
        </button>
      ))}
    </div>
    <div class="post-card-actions">
      {(post.commentCount ?? 0) > 0 && (
        <a href={localePath(locale, postPath)} class="comment-count-link" title={i.common.comments}>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          <span>{post.commentCount}</span>
        </a>
      )}
      <button
        class="share-card-btn"
        data-share-card
        type="button"
        aria-label="Share"
        title="Share"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
      </button>
      <button
        class:list={['bookmark-btn', { 'is-bookmarked': bookmarked }]}
        data-post-id={post.id}
        aria-label={bookmarked ? i.nav.saved : 'Save'}
        title={bookmarked ? i.nav.saved : 'Save'}
        type="button"
      >
        <svg class="bookmark-icon" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill={bookmarked ? 'currentColor' : 'none'} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m19 21-7-4-7 4V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2v16z"/></svg>
      </button>
    </div>
  </div>
</article>

<style>
  .post-card-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .comment-count-link {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.8rem;
    color: var(--surbias-text-muted);
    text-decoration: none;
    padding: 4px 6px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
  }

  .comment-count-link:hover {
    color: var(--surbias-primary);
    background: var(--surbias-warm-light);
  }

  .share-card-btn,
  .bookmark-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.8rem;
    color: var(--surbias-text-muted);
    padding: 6px;
    border-radius: 6px;
    transition: color 0.15s, background 0.15s;
    line-height: 1;
  }

  .share-card-btn:hover,
  .bookmark-btn:hover {
    color: var(--surbias-primary);
    background: var(--surbias-warm-light);
  }

  .bookmark-btn.is-bookmarked {
    color: var(--surbias-primary);
  }
</style>
