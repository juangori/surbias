---
import { t, localePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<footer class="site-footer">
  <div class="footer-grid">

    <!-- Column 1: Brand + tagline -->
    <div class="footer-col footer-col--brand">
      <a href={localePath(locale, '/')} class="footer-brand" aria-label="Surbias home">
        <img src="/logo.png" alt="" width="28" height="28" loading="lazy" />
        <span class="footer-brand-name">SURBIAS</span>
      </a>
      <p class="footer-tagline">{i.common.footer_text}</p>
      <a
        href="https://ko-fi.com/surbias"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-coffee"
      >
        ☕ {i.common.footer_coffee}
      </a>
    </div>

    <!-- Column 2: Explore -->
    <nav class="footer-col" aria-label="Explore">
      <h3 class="footer-heading">Explore</h3>
      <a href={localePath(locale, '/')}>{i.nav.home}</a>
      <a href={localePath(locale, '/top')}>Top stories</a>
      <a href="/random">Random story</a>
      <a href="/tags">Tags</a>
      <a href={localePath(locale, '/search')}>{i.nav.search}</a>
    </nav>

    <!-- Column 3: Read -->
    <nav class="footer-col" aria-label="Read">
      <h3 class="footer-heading">Read</h3>
      <a href={localePath(locale, '/about')}>{i.nav.about}</a>
      <a href="/blog">Blog</a>
      <a href="/survivorship-bias">What is survivorship bias?</a>
      <a href="/famous-failures">Famous failures</a>
      <a href="/glossary">Glossary</a>
    </nav>

    <!-- Column 4: Site -->
    <nav class="footer-col" aria-label="Site">
      <h3 class="footer-heading">Site</h3>
      <a href={localePath(locale, '/support')}>Why donate?</a>
      <a href="/faq">FAQ</a>
      <a href="/press">Press kit</a>
      <a href="/feed.xml">RSS</a>
      <a href={localePath(locale, '/stats')}>Stats</a>
      <a href={localePath(locale, '/terms')} class="footer-meta-link">{i.common.terms}</a>
      <a href={localePath(locale, '/privacy')} class="footer-meta-link">{i.common.privacy}</a>
    </nav>

  </div>

  <div class="footer-bottom">
    <span>© 2026 Surbias</span>
    <span aria-hidden="true">·</span>
    <span>Built with care · No ads · No trackers · Funded by readers</span>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--surbias-border);
    background-color: var(--surbias-header-bg);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 2rem 1.5rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-heading {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--surbias-text-muted);
    margin: 0 0 0.4rem;
  }

  .footer-col a {
    font-size: 0.86rem;
    color: var(--surbias-text-muted);
    text-decoration: none;
    transition: color 0.15s;
    line-height: 1.4;
  }
  .footer-col a:hover { color: var(--surbias-primary); }

  .footer-meta-link {
    margin-top: 0.5rem;
    font-size: 0.78rem !important;
    color: var(--surbias-text-light) !important;
  }
  .footer-meta-link:hover { color: var(--surbias-primary) !important; }

  /* Brand column */
  .footer-col--brand { gap: 0.75rem; }
  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .footer-brand-name {
    font-size: 0.95rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--surbias-text);
  }
  .footer-tagline {
    font-size: 0.85rem;
    color: var(--surbias-text-muted);
    margin: 0;
    line-height: 1.5;
  }
  .footer-coffee {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    background: linear-gradient(135deg, #fff8e1 0%, #ffe9a8 100%);
    color: #92600a;
    font-size: 0.82rem;
    font-weight: 700;
    border-radius: 9999px;
    text-decoration: none;
    border: 1px solid #f0d080;
    transition: transform 0.15s ease, box-shadow 0.2s ease, background 0.2s ease;
    box-shadow: 0 1px 3px rgba(184,134,11,0.18);
  }
  .footer-coffee:hover {
    background: linear-gradient(135deg, #ffefb3 0%, #ffdf85 100%);
    color: #6e4906 !important;
    transform: translateY(-1px);
    box-shadow: 0 4px 10px rgba(184,134,11,0.28);
  }

  .footer-bottom {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 1rem 2rem 1.75rem;
    font-size: 0.78rem;
    color: var(--surbias-text-light);
    border-top: 1px solid var(--surbias-border);
  }

  /* Tablet */
  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem 1.5rem;
      padding: 2rem 1.5rem 1.25rem;
    }
    .footer-col--brand { grid-column: 1 / -1; }
  }

  /* Mobile */
  @media (max-width: 540px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 1.75rem;
      padding: 1.75rem 1.25rem 1rem;
    }
    .footer-bottom {
      padding: 1rem 1.25rem 1.5rem;
      font-size: 0.74rem;
    }
  }
</style>
