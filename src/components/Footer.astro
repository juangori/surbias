---
import { t, localePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const i = t(locale);
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Brand -->
    <a href={localePath(locale, '/')} class="footer-logo" aria-label="Surbias home">
      <span class="logo-mark" aria-hidden="true">✕</span>
      <span class="logo-text">Surbias</span>
    </a>

    <p class="footer-tagline">{i.common.footer_text}</p>

    <!-- Nav links -->
    <nav class="footer-nav" aria-label="Footer navigation">
      <a href={localePath(locale, '/')}>{i.nav.home}</a>
      <span class="footer-sep" aria-hidden="true">|</span>
      <a href={localePath(locale, '/about')}>{i.nav.about}</a>
      <span class="footer-sep" aria-hidden="true">|</span>
      <a href={localePath(locale, '/post/new')}>{i.nav.share}</a>
    </nav>

    <!-- Ko-fi -->
    <a
      href="https://ko-fi.com/surbias"
      target="_blank"
      rel="noopener noreferrer"
      class="footer-coffee"
    >
      ☕ {i.common.footer_coffee}
    </a>

    <!-- Copyright -->
    <p class="footer-copy">© 2026 Surbias</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: auto;
    border-top: 1px solid var(--color-border);
    background-color: var(--color-surface-raised);
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    max-width: var(--container-max);
    margin: 0 auto;
    padding: var(--space-10) var(--space-4) var(--space-8);
    text-align: center;
  }

  /* Logo */
  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
  }

  .logo-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: var(--color-primary);
    color: #fff;
    border-radius: 5px;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
  }

  .logo-text {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
  }

  /* Tagline */
  .footer-tagline {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Nav row */
  .footer-nav {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-nav a {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color 0.15s;
  }

  .footer-nav a:hover {
    color: var(--color-primary);
  }

  .footer-sep {
    color: var(--color-border);
    font-size: 0.75rem;
    user-select: none;
  }

  /* Ko-fi link */
  .footer-coffee {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    background: var(--color-amber-soft);
    color: var(--color-amber-dark);
    font-size: 0.82rem;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background-color 0.15s;
  }

  .footer-coffee:hover {
    background: var(--color-amber-soft-hover);
  }

  /* Copyright */
  .footer-copy {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin: 0;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
    width: 100%;
    text-align: center;
  }
</style>
