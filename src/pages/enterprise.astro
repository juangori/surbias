---
import Base from '../layouts/Base.astro';
---
<Base title="Surbias for Teams">
  <div style="max-width: 700px; margin: 0 auto; padding: 3rem 1rem;">
    <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">Surbias for Teams</h1>
    <p style="color: var(--surbias-text-muted); font-size: 1.1rem; margin-bottom: 2rem;">
      Private failure-sharing for organizations. Learn from mistakes together.
    </p>

    <div style="display: grid; gap: 1rem; margin-bottom: 2rem;">
      <div class="sidebar-card">
        <p style="font-weight: 600; margin-bottom: 0.5rem;">🏢 Private Instance</p>
        <p style="color: var(--surbias-text-muted); font-size: 0.9rem; margin: 0;">Your own Surbias for your team. Share post-mortems, failed experiments, and lessons learned in a safe space.</p>
      </div>
      <div class="sidebar-card">
        <p style="font-weight: 600; margin-bottom: 0.5rem;">🔒 SSO & Privacy</p>
        <p style="color: var(--surbias-text-muted); font-size: 0.9rem; margin: 0;">SAML/OIDC single sign-on. Data stays within your organization. GDPR compliant.</p>
      </div>
      <div class="sidebar-card">
        <p style="font-weight: 600; margin-bottom: 0.5rem;">📊 Analytics</p>
        <p style="color: var(--surbias-text-muted); font-size: 0.9rem; margin: 0;">Team engagement metrics. Most discussed categories. Psychological safety score.</p>
      </div>
    </div>

    <p style="text-align: center; margin-top: 2rem;">
      <a href="mailto:enterprise@surbias.com" class="btn-cta">Contact us</a>
    </p>
  </div>
</Base>
