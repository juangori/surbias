---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import SupportCTA from '../../components/SupportCTA.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const blogJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  url: 'https://surbias.com/blog',
  name: 'Surbias blog',
  description: 'Notes on survivorship bias, anti-engagement social design, and what it takes to build a community for failure stories.',
  blogPost: allPosts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    datePublished: p.data.publishedAt.toISOString(),
    author: { '@type': 'Person', name: p.data.author },
    url: `https://surbias.com/blog/${p.id}`,
  })),
};
---

<Base
  title="Blog — Surbias"
  description="Notes from building Surbias: survivorship bias, anti-engagement design, and what it takes to keep a community for failure stories alive."
  jsonLd={blogJsonLd}
>
  <article class="blog-index">
    <header class="blog-header">
      <p class="pillar-eyebrow">Blog</p>
      <h1>Notes from building Surbias</h1>
      <p class="blog-sub">On survivorship bias, anti-engagement product design, and what it takes to run a social platform on tip-jar money.</p>
    </header>

    <ul class="blog-list">
      {allPosts.map((post) => (
        <li class="blog-list-item">
          <a href={`/blog/${post.id}`} class="blog-list-link">
            <time class="blog-date" datetime={post.data.publishedAt.toISOString()}>
              {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="blog-list-title">{post.data.title}</h2>
            <p class="blog-list-desc">{post.data.description}</p>
            <div class="blog-list-meta">
              {post.data.tags.map((t) => <span class="tag-pill">#{t}</span>)}
              <span style="color:var(--surbias-primary);font-weight:600;">Read →</span>
            </div>
          </a>
        </li>
      ))}
    </ul>

    {allPosts.length === 0 && (
      <p style="color:var(--surbias-text-muted);text-align:center;padding:3rem 1rem;">No blog posts yet — check back soon.</p>
    )}

    <div style="margin-top: 2.5rem;">
      <SupportCTA locale="en" variant="card" />
    </div>
  </article>
</Base>

<style>
  .blog-index { max-width: 720px; margin: 0 auto; padding: 1.25rem 1rem 3rem; }
  .blog-header { margin-bottom: 2rem; }
  .pillar-eyebrow { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: var(--surbias-warm); margin: 0 0 0.5rem; }
  .blog-header h1 { font-size: clamp(1.85rem, 5vw, 2.5rem); font-weight: 800; letter-spacing: -0.025em; margin: 0 0 0.5rem; line-height: 1.2; }
  .blog-sub { color: var(--surbias-text-muted); margin: 0; font-size: 1rem; }

  .blog-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1rem; }
  .blog-list-link {
    display: block;
    padding: 1.25rem 1.5rem;
    background: var(--surbias-card-bg);
    border: 1px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: var(--surbias-text);
    transition: border-color var(--dur-fast) var(--ease-out), transform var(--dur-fast) var(--ease-out), box-shadow var(--dur-base) var(--ease-out);
  }
  .blog-list-link:hover { border-color: var(--surbias-primary); transform: translateY(-2px); box-shadow: var(--shadow-md); color: var(--surbias-text); }
  .blog-date { font-size: 0.78rem; color: var(--surbias-text-light); font-weight: 600; }
  .blog-list-title { font-size: 1.25rem; font-weight: 800; letter-spacing: -0.02em; margin: 0.4rem 0 0.5rem; line-height: 1.3; color: var(--surbias-text); }
  .blog-list-desc { color: var(--surbias-text-muted); line-height: 1.6; margin: 0 0 0.75rem; font-size: 0.95rem; }
  .blog-list-meta { display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; font-size: 0.82rem; }
</style>
