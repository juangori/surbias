---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import SupportCTA from '../../components/SupportCTA.astro';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishedAt.toISOString(),
  dateModified: (post.data.updatedAt || post.data.publishedAt).toISOString(),
  author: { '@type': 'Person', name: post.data.author },
  publisher: { '@type': 'Organization', name: 'Surbias', logo: { '@type': 'ImageObject', url: 'https://surbias.com/logo.png' } },
  mainEntityOfPage: { '@type': 'WebPage', '@id': `https://surbias.com/blog/${post.id}` },
  image: 'https://surbias.com/logo.png',
  inLanguage: 'en',
};

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Surbias', item: 'https://surbias.com/' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://surbias.com/blog' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: `https://surbias.com/blog/${post.id}` },
  ],
};
---

<Base
  title={post.data.title}
  description={post.data.description}
  ogType="article"
  publishedTime={post.data.publishedAt.toISOString()}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <article class="blog-post">
    <header class="blog-post-header">
      <p class="pillar-eyebrow"><a href="/blog" style="color:var(--surbias-warm);text-decoration:none;">← Blog</a></p>
      <h1>{post.data.title}</h1>
      <p class="blog-post-meta">
        By {post.data.author} ·
        <time datetime={post.data.publishedAt.toISOString()}>
          {post.data.publishedAt.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
        {post.data.tags.length > 0 && (
          <span style="margin-left: 0.5rem;">
            {post.data.tags.map((t) => <span class="tag-pill" style="margin-right:0.25rem;">#{t}</span>)}
          </span>
        )}
      </p>
    </header>

    <div class="blog-prose">
      <Content />
    </div>

    <div style="margin-top: 2.5rem;">
      <SupportCTA locale="en" variant="card" />
    </div>

    <footer class="blog-post-footer">
      <p>← <a href="/blog">All blog posts</a></p>
    </footer>
  </article>
</Base>

<style>
  .blog-post { max-width: 700px; margin: 0 auto; padding: 1.25rem 1rem 3rem; }
  .blog-post-header { margin-bottom: 2rem; }
  .pillar-eyebrow { font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; margin: 0 0 0.75rem; }
  .blog-post-header h1 { font-size: clamp(1.85rem, 5vw, 2.5rem); font-weight: 800; letter-spacing: -0.025em; margin: 0 0 0.75rem; line-height: 1.2; color: var(--surbias-text); }
  .blog-post-meta { color: var(--surbias-text-muted); font-size: 0.88rem; margin: 0; }

  .blog-prose { line-height: 1.85; color: var(--surbias-text); font-size: 1.04rem; }
  .blog-prose :global(h2) { font-size: 1.45rem; font-weight: 800; letter-spacing: -0.02em; margin: 2.25rem 0 0.75rem; line-height: 1.3; }
  .blog-prose :global(h3) { font-size: 1.18rem; font-weight: 700; margin: 1.5rem 0 0.5rem; }
  .blog-prose :global(p) { margin-bottom: 1rem; }
  .blog-prose :global(a) { color: var(--surbias-primary); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 2px; }
  .blog-prose :global(ul), .blog-prose :global(ol) { padding-left: 1.5rem; margin-bottom: 1rem; }
  .blog-prose :global(li) { margin-bottom: 0.5rem; }
  .blog-prose :global(blockquote) {
    margin: 1.25rem 0;
    padding: 1rem 1.5rem;
    border-left: 4px solid var(--surbias-primary);
    background: var(--surbias-warm-light);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-style: italic;
    font-size: 1.08rem;
  }
  .blog-prose :global(code) {
    background: var(--surbias-warm-light);
    padding: 1px 6px;
    border-radius: 4px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.88em;
  }
  .blog-prose :global(strong) { color: var(--surbias-text); font-weight: 700; }
  .blog-prose :global(hr) { border: none; border-top: 1px solid var(--surbias-border); margin: 2rem 0; }

  .blog-post-footer { margin-top: 2.5rem; padding-top: 1.5rem; border-top: 1px solid var(--surbias-border); color: var(--surbias-text-muted); }
  .blog-post-footer a { color: var(--surbias-primary); }
</style>
