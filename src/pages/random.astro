---
import { getDb } from '../db';
import { posts } from '../db/schema';
import { eq, sql } from 'drizzle-orm';
import { env } from 'cloudflare:workers';

const db = getDb(env.DB);
const result = await db.select({ id: posts.id, slug: posts.slug, locale: posts.locale })
  .from(posts)
  .where(eq(posts.status, 'published'))
  .orderBy(sql`RANDOM()`)
  .limit(1);

const p = result[0];
if (!p) return Astro.redirect('/');
const path = p.slug ? `/post/${p.slug}-${p.id}` : `/post/${p.id}`;
const prefix = p.locale && p.locale !== 'en' ? `/${p.locale}` : '';
return Astro.redirect(`${prefix}${path}`, 302);
---
