  }
  .pillar-header { margin-bottom: 2rem; }
  .pillar-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--surbias-warm);
    margin: 0 0 0.5rem;
  }
