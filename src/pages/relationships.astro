---
import CategoryPage from '../components/pages/CategoryPage.astro';
---
<CategoryPage
  category="relationships"
  emoji="❤️‍🩹"
  accent="#c2627a"
  accentSoft="#fbe9ee"
  accentInk="#8e3f54"
  eyebrow="Relationships"
  hero="The version of love that didn't make it."
  lede="Breakups. Friendships that faded. Family you stopped calling. The person you were sure about until you weren't."
  intro={[
    "Most love stories don't end with a wedding photo. They end with a moving truck, a long silence, or a slow drift you didn't notice was happening.",
    "This page is for the relationships that mattered and didn't last — the partner, the best friend, the parent, the sibling. The version of yourself you were with them, who is also gone now.",
    "It's allowed to grieve a connection nobody else thinks you should grieve. Write it down. Someone here gets it.",
  ]}
  prompt="Who did you lose that you're still mourning quietly?"
  metaTitle="Relationship failure stories — breakups, friendships, family you stopped calling"
  metaDescription="Real relationship failure stories: breakups, lost friendships, family fractures. The honest, gentle, unedited version."
/>
