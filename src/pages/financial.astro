---
import CategoryPage from '../components/pages/CategoryPage.astro';
---
<CategoryPage
  category="financial"
  emoji="💸"
  accent="#c97a3f"
  accentSoft="#fbe9d9"
  accentInk="#8a4f1f"
  eyebrow="Financial"
  hero="Money that disappeared."
  lede="The crypto bag. The car you couldn't afford. The credit-card spiral. The rent that ate the paycheck and then ate the next one."
  intro={[
    "Personal finance Twitter is a survivorship-bias machine. The people who got into the right asset at the right time get loud. The people who didn't get quiet.",
    "This page is for the bad investments, the layoff that happened the month after you took on the mortgage, the years of cost-of-living that quietly hollowed out your savings.",
    "Money problems aren't a character flaw. They're a math problem in a system that's mostly tilted away from you. Saying that out loud helps.",
  ]}
  prompt="What did money cost you that money was supposed to fix?"
  metaTitle="Financial failure stories — debt, bad investments, the cost-of-living crisis"
  metaDescription="Real financial failure stories: debt, bad investments, money that disappeared, paychecks that didn't stretch. No grift, no get-rich-quick."
/>
