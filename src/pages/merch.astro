---
import Base from '../layouts/Base.astro';
---
<Base title="Merch">
  <div style="text-align: center; padding: 4rem 1rem; max-width: 600px; margin: 0 auto;">
    <h1 style="font-size: 2rem; margin-bottom: 1rem;">Merch Store</h1>
    <p style="color: var(--surbias-text-muted); font-size: 1.1rem; margin-bottom: 2rem;">
      "Because Failing is Normal" t-shirts, mugs, and stickers coming soon.
    </p>
    <div style="padding: 3rem; border: 2px dashed var(--surbias-border); border-radius: var(--radius-lg); margin-bottom: 2rem;">
      <p style="font-size: 3rem; margin-bottom: 0.5rem;">👕</p>
      <p style="color: var(--surbias-text-muted);">Store opening soon. Stay tuned!</p>
    </div>
    <a href="/" class="btn-cta">Back to stories</a>
  </div>
</Base>
