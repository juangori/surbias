---
import Base from '../layouts/Base.astro';
---
<Base title="Server error">
  <div style="text-align: center; padding: 4rem 1rem;">
    <h1 style="font-size: 4rem; margin-bottom: 0.5rem; color: var(--surbias-text-light);">500</h1>
    <p style="font-size: 1.2rem; color: var(--surbias-text-muted); margin-bottom: 2rem;">Something went wrong on our end.</p>
    <a href="/" class="btn-cta">Go home</a>
  </div>
</Base>
