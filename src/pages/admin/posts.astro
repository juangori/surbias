---
import Base from '../../layouts/Base.astro';
import { getDb } from '../../db';
import { posts, users } from '../../db/schema';
import { desc, eq, and } from 'drizzle-orm';
import { createAuth } from '../../lib/auth';
import { env } from 'cloudflare:workers';
import ChartBar from '@lucide/astro/icons/chart-bar';
import Users from '@lucide/astro/icons/users';
import FileText from '@lucide/astro/icons/file-text';
import Flag from '@lucide/astro/icons/flag';
import Shield from '@lucide/astro/icons/shield';
import Trash2 from '@lucide/astro/icons/trash-2';
import CircleCheck from '@lucide/astro/icons/circle-check';
import CircleX from '@lucide/astro/icons/circle-x';
import { CATEGORIES } from '../../db/schema';

// Admin auth check
const auth = createAuth(env);
const session = await auth.api.getSession({ headers: Astro.request.headers });
const isAdmin = session?.user?.email === env.ADMIN_EMAIL;
if (!isAdmin) return Astro.redirect('/login');

const db = getDb(env.DB);

// Filters from URL
const statusFilter = Astro.url.searchParams.get('status') ?? 'all';
const categoryFilter = Astro.url.searchParams.get('category') ?? 'all';
const userIdFilter = Astro.url.searchParams.get('userId') ?? '';

// Build query conditions
const conditions: ReturnType<typeof eq>[] = [];

if (statusFilter !== 'all') {
  conditions.push(eq(posts.status, statusFilter));
}
if (categoryFilter !== 'all') {
  conditions.push(eq(posts.category, categoryFilter));
}
if (userIdFilter) {
  conditions.push(eq(posts.userId, userIdFilter));
}

const allPosts = await db
  .select()
  .from(posts)
  .where(conditions.length > 0 ? and(...conditions) : undefined)
  .orderBy(desc(posts.createdAt))
  .limit(100);

function normalizeDate(val: unknown): Date {
  if (val instanceof Date) return val;
  if (typeof val === 'number') return new Date(val * 1000);
  return new Date(String(val));
}

function timeAgo(date: Date): string {
  const diff = Date.now() - date.getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  return `${Math.floor(hrs / 24)}d ago`;
}

const statuses = ['all', 'published', 'flagged', 'deleted'];
---

<Base title="Admin — Posts">
  <div class="admin-layout">
    <!-- Sidebar -->
    <nav class="admin-sidebar">
      <div class="admin-sidebar-logo">
        <Shield size={20} />
        <span>Admin</span>
      </div>
      <ul class="admin-nav-links">
        <li><a href="/admin"><ChartBar size={16} /> Dashboard</a></li>
        <li><a href="/admin/users"><Users size={16} /> Users</a></li>
        <li><a href="/admin/posts" class="active"><FileText size={16} /> Posts</a></li>
        <li><a href="/admin/flags"><Flag size={16} /> Flags</a></li>
      </ul>
    </nav>

    <!-- Main content -->
    <div class="admin-main">
      <header class="admin-page-header">
        <h1>Posts</h1>
        <p class="admin-subtitle">{allPosts.length} post{allPosts.length !== 1 ? 's' : ''}{statusFilter !== 'all' ? ` — ${statusFilter}` : ''}{categoryFilter !== 'all' ? `, ${categoryFilter}` : ''}</p>
      </header>

      <!-- Filters -->
      <div class="admin-filters">
        <div class="admin-filter-group">
          <span class="admin-filter-label">Status:</span>
          {statuses.map((s) => (
            <a
              href={`/admin/posts?status=${s}&category=${categoryFilter}`}
              class={`admin-filter-btn ${statusFilter === s ? 'active' : ''}`}
            >
              {s.charAt(0).toUpperCase() + s.slice(1)}
            </a>
          ))}
        </div>

        <div class="admin-filter-group">
          <span class="admin-filter-label">Category:</span>
          <a
            href={`/admin/posts?status=${statusFilter}&category=all`}
            class={`admin-filter-btn ${categoryFilter === 'all' ? 'active' : ''}`}
          >
            All
          </a>
          {CATEGORIES.map((cat) => (
            <a
              href={`/admin/posts?status=${statusFilter}&category=${cat}`}
              class={`admin-filter-btn ${categoryFilter === cat ? 'active' : ''}`}
            >
              {cat.charAt(0).toUpperCase() + cat.slice(1)}
            </a>
          ))}
        </div>

        {userIdFilter && (
          <div class="admin-filter-group">
            <span class="admin-filter-label">Filtered by user</span>
            <a href="/admin/posts" class="admin-filter-btn">Clear</a>
          </div>
        )}
      </div>

      {allPosts.length === 0 ? (
        <div class="notice notice-info">No posts found with the selected filters.</div>
      ) : (
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Title</th>
                <th>Category</th>
                <th>Status</th>
                <th>Flags</th>
                <th>Posted</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              {allPosts.map((post) => {
                const date = normalizeDate(post.createdAt);
                return (
                  <tr data-post-id={post.id}>
                    <td>
                      <a href={`/post/${post.id}`} class="admin-link" target="_blank" rel="noopener">
                        {post.title.slice(0, 55)}{post.title.length > 55 ? '…' : ''}
                      </a>
                    </td>
                    <td><span class="category-badge">{post.category}</span></td>
                    <td>
                      <span class={`admin-status admin-status--${post.status}`}>
                        {post.status}
                      </span>
                    </td>
                    <td>
                      {post.flagCount > 0
                        ? <span class="admin-flag-count">{post.flagCount}</span>
                        : <span class="admin-muted">—</span>
                      }
                    </td>
                    <td class="admin-muted">{timeAgo(date)}</td>
                    <td>
                      <div class="admin-actions" style="margin-top: 0; gap: 0.35rem;">
                        {post.status !== 'published' && (
                          <button
                            class="admin-btn admin-btn--success"
                            data-action="restore_post"
                            data-post-id={post.id}
                            title="Restore post"
                          >
                            <CircleCheck size={13} /> Restore
                          </button>
                        )}
                        {post.status !== 'deleted' && (
                          <button
                            class="admin-btn admin-btn--danger"
                            data-action="delete_post"
                            data-post-id={post.id}
                            title="Delete post"
                          >
                            <Trash2 size={13} /> Delete
                          </button>
                        )}
                        {post.status === 'flagged' && (
                          <button
                            class="admin-btn admin-btn--warn"
                            data-action="dismiss_flags"
                            data-post-id={post.id}
                            title="Dismiss flags"
                          >
                            <CircleX size={13} /> Dismiss
                          </button>
                        )}
                      </div>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</Base>

<script>
  document.querySelectorAll('[data-action]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const el = btn as HTMLElement;
      const action = el.dataset.action!;
      const postId = el.dataset.postId!;

      if (action === 'delete_post' && !confirm('Permanently delete this post?')) return;

      el.setAttribute('disabled', 'true');

      const res = await fetch('/api/admin/moderate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ action, postId }),
      });

      if (res.ok) {
        const row = el.closest('tr');
        if (!row) return;

        if (action === 'delete_post') {
          const statusEl = row.querySelector('.admin-status');
          if (statusEl) {
            statusEl.textContent = 'deleted';
            statusEl.className = 'admin-status admin-status--deleted';
          }
          // Remove delete + dismiss buttons, show restore
          row.querySelectorAll('[data-action="delete_post"], [data-action="dismiss_flags"]').forEach(b => b.remove());
          const existingRestore = row.querySelector('[data-action="restore_post"]');
          if (!existingRestore) {
            const actionsEl = row.querySelector('.admin-actions');
            if (actionsEl) {
              const restoreBtn = document.createElement('button');
              restoreBtn.className = 'admin-btn admin-btn--success';
              restoreBtn.dataset.action = 'restore_post';
              restoreBtn.dataset.postId = postId;
              restoreBtn.innerHTML = '&#10003; Restore';
              actionsEl.prepend(restoreBtn);
              // Re-attach listener
              restoreBtn.addEventListener('click', () => restoreBtn.click());
            }
          }
        } else if (action === 'restore_post') {
          const statusEl = row.querySelector('.admin-status');
          if (statusEl) {
            statusEl.textContent = 'published';
            statusEl.className = 'admin-status admin-status--published';
          }
          row.querySelectorAll('[data-action="restore_post"]').forEach(b => b.remove());
        } else if (action === 'dismiss_flags') {
          const statusEl = row.querySelector('.admin-status');
          if (statusEl) {
            statusEl.textContent = 'published';
            statusEl.className = 'admin-status admin-status--published';
          }
          const flagEl = row.querySelector('.admin-flag-count');
          if (flagEl) flagEl.textContent = '—';
          row.querySelectorAll('[data-action="dismiss_flags"], [data-action="restore_post"]').forEach(b => b.remove());
        }
      } else {
        alert('Action failed. Please try again.');
      }

      el.removeAttribute('disabled');
    });
  });
</script>

<style>
  .admin-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    min-height: calc(100vh - 120px);
    align-items: start;
  }

  .admin-sidebar {
    position: sticky;
    top: 1.5rem;
    background: var(--surbias-card-bg);
    border: 1.5px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1rem;
    box-shadow: var(--shadow-sm);
  }

  .admin-sidebar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1rem;
    color: var(--surbias-primary);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--surbias-border);
    margin-bottom: 1rem;
  }

  .admin-nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .admin-nav-links a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.75rem;
    border-radius: var(--radius-md);
    color: var(--surbias-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }

  .admin-nav-links a:hover,
  .admin-nav-links a.active {
    background: var(--surbias-warm-light);
    color: var(--surbias-primary);
  }

  .admin-page-header { margin-bottom: 1.5rem; }
  .admin-page-header h1 {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.2rem;
  }
  .admin-subtitle { color: var(--surbias-text-muted); font-size: 0.9rem; margin: 0; }

  /* Filters */
  .admin-filters {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin-bottom: 1.25rem;
  }

  .admin-filter-group {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .admin-filter-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--surbias-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-right: 0.25rem;
    white-space: nowrap;
  }

  .admin-filter-btn {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    border-radius: var(--radius-pill);
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--surbias-text-muted);
    background: var(--surbias-card-bg);
    border: 1px solid var(--surbias-border);
    text-decoration: none;
    transition: all var(--dur-fast);
  }

  .admin-filter-btn:hover,
  .admin-filter-btn.active {
    background: var(--surbias-primary);
    color: white;
    border-color: var(--surbias-primary);
  }

  /* Table */
  .admin-table-wrap {
    background: var(--surbias-card-bg);
    border: 1.5px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .admin-table thead th {
    background: var(--surbias-warm-light);
    padding: 0.7rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--surbias-text-muted);
    border-bottom: 1px solid var(--surbias-border);
  }

  .admin-table tbody td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--surbias-border);
    vertical-align: middle;
  }

  .admin-table tbody tr:last-child td { border-bottom: none; }
  .admin-table tbody tr:hover td { background: var(--surbias-warm-light); }

  .admin-link {
    color: var(--surbias-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .admin-link:hover { text-decoration: underline; }

  .admin-muted { color: var(--surbias-text-muted); font-size: 0.8rem; }

  .admin-status {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: capitalize;
  }
  .admin-status--published { background: var(--surbias-success-light); color: var(--surbias-success); }
  .admin-status--flagged   { background: #fef3c7; color: #92400e; }
  .admin-status--deleted   { background: var(--surbias-danger-light); color: var(--surbias-danger); }

  .admin-flag-count {
    display: inline-block;
    background: var(--surbias-danger-light);
    color: var(--surbias-danger);
    font-weight: 700;
    font-size: 0.78rem;
    padding: 0.1rem 0.45rem;
    border-radius: var(--radius-pill);
  }

  .admin-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.3rem 0.65rem;
    border: none;
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity var(--dur-fast);
    white-space: nowrap;
  }
  .admin-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .admin-btn--danger  { background: var(--surbias-danger-light); color: var(--surbias-danger); }
  .admin-btn--success { background: var(--surbias-success-light); color: var(--surbias-success); }
  .admin-btn--warn    { background: #fef3c7; color: #92400e; }
  .admin-btn:hover:not(:disabled) { opacity: 0.75; }

  @media (max-width: 768px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; }
    .admin-nav-links { flex-direction: row; flex-wrap: wrap; }
    .admin-table { font-size: 0.8rem; }
    .admin-table thead th,
    .admin-table tbody td { padding: 0.5rem 0.6rem; }
  }
</style>
