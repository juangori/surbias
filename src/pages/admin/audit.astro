---
import Base from '../../layouts/Base.astro';
import { getDb } from '../../db';
import { users, auditLogs } from '../../db/schema';
import { desc, eq } from 'drizzle-orm';
import { createAuth } from '../../lib/auth';
import { env } from 'cloudflare:workers';
import ChartBar from '@lucide/astro/icons/chart-bar';
import Users from '@lucide/astro/icons/users';
import FileText from '@lucide/astro/icons/file-text';
import Flag from '@lucide/astro/icons/flag';
import Shield from '@lucide/astro/icons/shield';
import ClipboardList from '@lucide/astro/icons/clipboard-list';
import MessageSquare from '@lucide/astro/icons/message-square';

// Admin auth check (role-based)
const auth = createAuth(env);
const session = await auth.api.getSession({ headers: Astro.request.headers });
const db = getDb(env.DB);
const userRecord = session?.user ? await db.select().from(users).where(eq(users.id, session.user.id)).limit(1) : [];
const isAdmin = userRecord[0]?.role === 'admin';
if (!isAdmin) return Astro.redirect('/login');

// Query audit logs newest first, limit 100
const logs = await db
  .select()
  .from(auditLogs)
  .orderBy(desc(auditLogs.createdAt))
  .limit(100);

function normalizeDate(val: unknown): Date {
  if (val instanceof Date) return val;
  if (typeof val === 'number') return new Date(val * 1000);
  return new Date(String(val));
}

function formatDate(date: Date): string {
  return date.toLocaleString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric',
    hour: '2-digit', minute: '2-digit',
  });
}
---

<Base title="Admin — Audit Log">
  <div class="admin-layout">
    <!-- Sidebar -->
    <nav class="admin-sidebar">
      <div class="admin-sidebar-logo">
        <Shield size={20} />
        <span>Admin</span>
      </div>
      <ul class="admin-nav-links">
        <li><a href="/admin"><ChartBar size={16} /> Dashboard</a></li>
        <li><a href="/admin/users"><Users size={16} /> Users</a></li>
        <li><a href="/admin/posts"><FileText size={16} /> Posts</a></li>
        <li><a href="/admin/comments"><MessageSquare size={16} /> Comments</a></li>
        <li><a href="/admin/flags"><Flag size={16} /> Flags</a></li>
        <li><a href="/admin/audit" class="active"><ClipboardList size={16} /> Audit Log</a></li>
      </ul>
    </nav>

    <!-- Main content -->
    <div class="admin-main">
      <header class="admin-page-header">
        <h1>Audit Log</h1>
        <p class="admin-subtitle">{logs.length} recent action{logs.length !== 1 ? 's' : ''}</p>
      </header>

      {logs.length === 0 ? (
        <div class="notice notice-info">No audit log entries yet.</div>
      ) : (
        <div class="admin-table-wrap">
          <table class="admin-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Actor</th>
                <th>Action</th>
                <th>Target Type</th>
                <th>Target ID</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              {logs.map((log) => {
                const date = normalizeDate(log.createdAt);
                return (
                  <tr>
                    <td class="admin-muted admin-nowrap">{formatDate(date)}</td>
                    <td>
                      <span class="admin-actor-email">{log.actorEmail}</span>
                    </td>
                    <td>
                      <span class={`admin-action-badge admin-action-badge--${log.action.includes('delete') || log.action.includes('ban') ? 'danger' : log.action.includes('restore') || log.action.includes('unban') ? 'success' : 'neutral'}`}>
                        {log.action}
                      </span>
                    </td>
                    <td class="admin-muted">{log.targetType}</td>
                    <td class="admin-mono admin-muted">{log.targetId.slice(0, 12)}{log.targetId.length > 12 ? '…' : ''}</td>
                    <td class="admin-muted admin-details">{log.details ?? '—'}</td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>
</Base>

<style>
  .admin-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    min-height: calc(100vh - 120px);
    align-items: start;
  }

  .admin-sidebar {
    position: sticky;
    top: 1.5rem;
    background: var(--surbias-card-bg);
    border: 1.5px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1rem;
    box-shadow: var(--shadow-sm);
  }

  .admin-sidebar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1rem;
    color: var(--surbias-primary);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--surbias-border);
    margin-bottom: 1rem;
  }

  .admin-nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .admin-nav-links a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.75rem;
    border-radius: var(--radius-md);
    color: var(--surbias-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }

  .admin-nav-links a:hover,
  .admin-nav-links a.active {
    background: var(--surbias-warm-light);
    color: var(--surbias-primary);
  }

  .admin-page-header { margin-bottom: 1.5rem; }
  .admin-page-header h1 {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.2rem;
  }
  .admin-subtitle { color: var(--surbias-text-muted); font-size: 0.9rem; margin: 0; }

  /* Table */
  .admin-table-wrap {
    background: var(--surbias-card-bg);
    border: 1.5px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .admin-table thead th {
    background: var(--surbias-warm-light);
    padding: 0.7rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--surbias-text-muted);
    border-bottom: 1px solid var(--surbias-border);
  }

  .admin-table tbody td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--surbias-border);
    vertical-align: middle;
  }

  .admin-table tbody tr:last-child td { border-bottom: none; }
  .admin-table tbody tr:hover td { background: var(--surbias-warm-light); }

  .admin-muted { color: var(--surbias-text-muted); font-size: 0.8rem; }
  .admin-mono { font-family: monospace; font-size: 0.78rem; }
  .admin-nowrap { white-space: nowrap; }

  .admin-actor-email {
    font-weight: 500;
    color: var(--surbias-text);
    font-size: 0.85rem;
  }

  .admin-action-badge {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    font-weight: 600;
    font-family: monospace;
  }
  .admin-action-badge--danger  { background: var(--surbias-danger-light); color: var(--surbias-danger); }
  .admin-action-badge--success { background: var(--surbias-success-light); color: var(--surbias-success); }
  .admin-action-badge--neutral { background: var(--surbias-warm-light); color: var(--surbias-text-muted); }

  .admin-details {
    font-family: monospace;
    font-size: 0.72rem;
    max-width: 200px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .admin-layout { grid-template-columns: 1fr; }
    .admin-sidebar { position: static; }
    .admin-nav-links { flex-direction: row; flex-wrap: wrap; }
    .admin-table { font-size: 0.8rem; }
    .admin-table thead th,
    .admin-table tbody td { padding: 0.5rem 0.6rem; }
  }
</style>
