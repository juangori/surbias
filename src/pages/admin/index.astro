---
import Base from '../../layouts/Base.astro';
import { getDb } from '../../db';
import { posts, users, flags } from '../../db/schema';
import { eq, desc, gte, count, sql } from 'drizzle-orm';
import { createAuth } from '../../lib/auth';
import { env } from 'cloudflare:workers';
import ChartBar from '@lucide/astro/icons/chart-bar';
import Users from '@lucide/astro/icons/users';
import FileText from '@lucide/astro/icons/file-text';
import Flag from '@lucide/astro/icons/flag';
import Shield from '@lucide/astro/icons/shield';

// Admin auth check
const auth = createAuth(env);
const session = await auth.api.getSession({ headers: Astro.request.headers });
const isAdmin = session?.user?.email === env.ADMIN_EMAIL;
if (!isAdmin) return Astro.redirect('/login');

const db = getDb(env.DB);

// Stats
const [totalUsersResult] = await db.select({ count: count() }).from(users);
const [totalPostsResult] = await db.select({ count: count() }).from(posts);
const [flaggedPostsResult] = await db.select({ count: count() }).from(posts).where(eq(posts.status, 'flagged'));

const todayStart = new Date();
todayStart.setHours(0, 0, 0, 0);
const [postsTodayResult] = await db.select({ count: count() }).from(posts).where(gte(posts.createdAt, todayStart));

const totalUsers = totalUsersResult?.count ?? 0;
const totalPosts = totalPostsResult?.count ?? 0;
const flaggedCount = flaggedPostsResult?.count ?? 0;
const postsToday = postsTodayResult?.count ?? 0;

// Recent activity (latest 10 posts)
const recentPosts = await db
  .select()
  .from(posts)
  .orderBy(desc(posts.createdAt))
  .limit(10);

function timeAgo(date: Date): string {
  const diff = Date.now() - date.getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 1) return 'just now';
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  return `${Math.floor(hrs / 24)}d ago`;
}

function normalizeDate(val: unknown): Date {
  if (val instanceof Date) return val;
  if (typeof val === 'number') return new Date(val * 1000);
  return new Date(String(val));
}
---

<Base title="Admin Dashboard">
  <div class="admin-layout">
    <!-- Sidebar -->
    <nav class="admin-sidebar">
      <div class="admin-sidebar-logo">
        <Shield size={20} />
        <span>Admin</span>
      </div>
      <ul class="admin-nav-links">
        <li><a href="/admin" class="active"><ChartBar size={16} /> Dashboard</a></li>
        <li><a href="/admin/users"><Users size={16} /> Users</a></li>
        <li><a href="/admin/posts"><FileText size={16} /> Posts</a></li>
        <li><a href="/admin/flags"><Flag size={16} /> Flags {flaggedCount > 0 && <span class="admin-badge">{flaggedCount}</span>}</a></li>
      </ul>
    </nav>

    <!-- Main content -->
    <div class="admin-main">
      <header class="admin-page-header">
        <h1>Dashboard</h1>
        <p class="admin-subtitle">Welcome back, {session?.user?.name ?? session?.user?.email}</p>
      </header>

      <!-- Stats cards -->
      <div class="admin-stats-grid">
        <div class="admin-stat-card">
          <div class="admin-stat-icon admin-stat-icon--green">
            <Users size={22} />
          </div>
          <div class="admin-stat-body">
            <div class="admin-stat-value">{totalUsers}</div>
            <div class="admin-stat-label">Total Users</div>
          </div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-icon admin-stat-icon--blue">
            <FileText size={22} />
          </div>
          <div class="admin-stat-body">
            <div class="admin-stat-value">{totalPosts}</div>
            <div class="admin-stat-label">Total Posts</div>
          </div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-icon admin-stat-icon--red">
            <Flag size={22} />
          </div>
          <div class="admin-stat-body">
            <div class="admin-stat-value">{flaggedCount}</div>
            <div class="admin-stat-label">Flagged Posts</div>
          </div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-icon admin-stat-icon--warm">
            <ChartBar size={22} />
          </div>
          <div class="admin-stat-body">
            <div class="admin-stat-value">{postsToday}</div>
            <div class="admin-stat-label">Posts Today</div>
          </div>
        </div>
      </div>

      <!-- Quick links -->
      <div class="admin-section">
        <h2 class="admin-section-title">Quick Actions</h2>
        <div class="admin-quick-links">
          <a href="/admin/flags" class="admin-quick-link">
            <Flag size={18} />
            Review Flags
            {flaggedCount > 0 && <span class="admin-badge">{flaggedCount} pending</span>}
          </a>
          <a href="/admin/users" class="admin-quick-link">
            <Users size={18} />
            Manage Users
          </a>
          <a href="/admin/posts" class="admin-quick-link">
            <FileText size={18} />
            All Posts
          </a>
        </div>
      </div>

      <!-- Recent activity -->
      <div class="admin-section">
        <h2 class="admin-section-title">Recent Activity</h2>
        {recentPosts.length === 0 ? (
          <div class="notice notice-info">No posts yet.</div>
        ) : (
          <div class="admin-table-wrap">
            <table class="admin-table">
              <thead>
                <tr>
                  <th>Title</th>
                  <th>Category</th>
                  <th>Status</th>
                  <th>Flags</th>
                  <th>Posted</th>
                </tr>
              </thead>
              <tbody>
                {recentPosts.map((post) => {
                  const date = normalizeDate(post.createdAt);
                  return (
                    <tr>
                      <td>
                        <a href={`/post/${post.id}`} class="admin-link">{post.title.slice(0, 60)}{post.title.length > 60 ? '…' : ''}</a>
                      </td>
                      <td><span class="category-badge">{post.category}</span></td>
                      <td><span class={`admin-status admin-status--${post.status}`}>{post.status}</span></td>
                      <td>{post.flagCount > 0 ? <span class="admin-flag-count">{post.flagCount}</span> : '—'}</td>
                      <td class="admin-muted">{timeAgo(date)}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
        )}
      </div>
    </div>
  </div>
</Base>

<style>
  /* Layout */
  .admin-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 2rem;
    min-height: calc(100vh - 120px);
    align-items: start;
  }

  /* Sidebar */
  .admin-sidebar {
    position: sticky;
    top: 1.5rem;
    background: var(--surbias-card-bg);
    border: 1.5px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 1rem;
    box-shadow: var(--shadow-sm);
  }

  .admin-sidebar-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1rem;
    color: var(--surbias-primary);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--surbias-border);
    margin-bottom: 1rem;
  }

  .admin-nav-links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .admin-nav-links a {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.75rem;
    border-radius: var(--radius-md);
    color: var(--surbias-text-muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast) var(--ease-out);
  }

  .admin-nav-links a:hover,
  .admin-nav-links a.active {
    background: var(--surbias-warm-light);
    color: var(--surbias-primary);
  }

  /* Page header */
  .admin-page-header {
    margin-bottom: 1.75rem;
  }

  .admin-page-header h1 {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 0.2rem;
  }

  .admin-subtitle {
    color: var(--surbias-text-muted);
    font-size: 0.9rem;
    margin: 0;
  }

  /* Stats grid */
  .admin-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .admin-stat-card {
    background: var(--surbias-card-bg);
    border: 1.5px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    box-shadow: var(--shadow-sm);
  }

  .admin-stat-icon {
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .admin-stat-icon--green { background: var(--surbias-success-light); color: var(--surbias-success); }
  .admin-stat-icon--blue  { background: #dbeafe; color: #1d4ed8; }
  .admin-stat-icon--red   { background: var(--surbias-danger-light); color: var(--surbias-danger); }
  .admin-stat-icon--warm  { background: #fef3c7; color: #92400e; }

  .admin-stat-value {
    font-size: 1.6rem;
    font-weight: 800;
    line-height: 1;
    color: var(--surbias-text);
  }

  .admin-stat-label {
    font-size: 0.78rem;
    color: var(--surbias-text-muted);
    margin-top: 0.2rem;
    font-weight: 500;
  }

  /* Section */
  .admin-section {
    margin-bottom: 2rem;
  }

  .admin-section-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--surbias-text);
    margin: 0 0 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.78rem;
  }

  /* Quick links */
  .admin-quick-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .admin-quick-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.1rem;
    background: var(--surbias-card-bg);
    border: 1.5px solid var(--surbias-border);
    border-radius: var(--radius-pill);
    color: var(--surbias-text);
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: border-color var(--dur-fast), background var(--dur-fast), color var(--dur-fast);
  }

  .admin-quick-link:hover {
    border-color: var(--surbias-primary);
    color: var(--surbias-primary);
    background: var(--surbias-warm-light);
  }

  /* Table */
  .admin-table-wrap {
    background: var(--surbias-card-bg);
    border: 1.5px solid var(--surbias-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }

  .admin-table thead th {
    background: var(--surbias-warm-light);
    padding: 0.7rem 1rem;
    text-align: left;
    font-weight: 600;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--surbias-text-muted);
    border-bottom: 1px solid var(--surbias-border);
  }

  .admin-table tbody td {
    padding: 0.7rem 1rem;
    border-bottom: 1px solid var(--surbias-border);
    vertical-align: middle;
  }

  .admin-table tbody tr:last-child td { border-bottom: none; }
  .admin-table tbody tr:hover td { background: var(--surbias-warm-light); }

  .admin-link {
    color: var(--surbias-primary);
    text-decoration: none;
    font-weight: 500;
  }
  .admin-link:hover { text-decoration: underline; }

  .admin-muted { color: var(--surbias-text-muted); font-size: 0.8rem; }

  .admin-status {
    display: inline-block;
    padding: 0.15rem 0.55rem;
    border-radius: var(--radius-pill);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: capitalize;
  }
  .admin-status--published { background: var(--surbias-success-light); color: var(--surbias-success); }
  .admin-status--flagged   { background: #fef3c7; color: #92400e; }
  .admin-status--deleted   { background: var(--surbias-danger-light); color: var(--surbias-danger); }

  .admin-flag-count {
    display: inline-block;
    background: var(--surbias-danger-light);
    color: var(--surbias-danger);
    font-weight: 700;
    font-size: 0.78rem;
    padding: 0.1rem 0.45rem;
    border-radius: var(--radius-pill);
  }

  .admin-badge {
    display: inline-block;
    background: var(--surbias-danger);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: var(--radius-pill);
    margin-left: 0.25rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .admin-layout {
      grid-template-columns: 1fr;
    }
    .admin-sidebar {
      position: static;
    }
    .admin-nav-links {
      flex-direction: row;
      flex-wrap: wrap;
    }
    .admin-stats-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 480px) {
    .admin-stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
