---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getLocaleFromUrl, t } from '../i18n';

interface Props {
  title?: string;
  description?: string;
}

const locale = getLocaleFromUrl(Astro.url);
const i = t(locale);
const { title = i.site.title, description = i.site.description } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://surbias.com');
const pageTitle = title === i.site.title ? `${i.site.title} — ${i.site.tagline}` : `${title} | Surbias`;
---

<!DOCTYPE html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Surbias" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/logo.png" />

    <!-- Outfit font -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Global styles -->
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <Header locale={locale} />
    <main class="container">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
