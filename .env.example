# Required secrets (set via: npx wrangler secret put <NAME>)
BETTER_AUTH_SECRET=       # Random 32+ char string for session signing
TURNSTILE_SECRET_KEY=     # Cloudflare Turnstile secret key
RESEND_API_KEY=           # Resend API key for transactional email
GOOGLE_CLIENT_ID=         # Google OAuth client ID (optional)
GOOGLE_CLIENT_SECRET=     # Google OAuth client secret (optional)

# Public vars (set in wrangler.json)
TURNSTILE_SITE_KEY=       # Cloudflare Turnstile site key
BETTER_AUTH_URL=          # Site URL (e.g., https://surbias.com)
ADMIN_EMAIL=              # Admin email for initial setup
FROM_EMAIL=               # Sender address (e.g., Surbias <noreply@surbias.com>)

# Infrastructure IDs (for deploy.sh)
KV_NAMESPACE_ID=          # Cloudflare KV namespace ID for sessions
D1_DATABASE_ID=           # Cloudflare D1 database ID
