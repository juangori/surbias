# ============================================================
#  Required secrets (set via: npx wrangler secret put <NAME>)
# ============================================================
BETTER_AUTH_SECRET=       # Random 32+ char string for session signing
TURNSTILE_SECRET_KEY=     # Cloudflare Turnstile secret key
GOOGLE_CLIENT_ID=         # Google OAuth client ID (optional)
GOOGLE_CLIENT_SECRET=     # Google OAuth client secret (optional)

# ============================================================
#  Email — pick ONE provider (first set wins, in this order)
# ============================================================
# 1) Brevo — RECOMMENDED. 300/day free, no card required.
#    Sign up: https://brevo.com  →  SMTP & API → Generate v3 key
BREVO_API_KEY=

# 2) Mailjet — 200/day free.   https://app.mailjet.com/account/api_keys
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

# 3) SendGrid — 100/day free (Twilio).   https://app.sendgrid.com
SENDGRID_API_KEY=

# 4) Resend — 100/day free, but 1 sender per free account.
#    Already in use elsewhere → leave blank to fall through.
RESEND_API_KEY=

# Sender display ("Surbias <noreply@surbias.com>" or just "noreply@surbias.com")
# Must be a domain you've verified with the chosen provider.
FROM_EMAIL=Surbias <noreply@surbias.com>

# ============================================================
#  Public vars (set in wrangler.json [vars])
# ============================================================
TURNSTILE_SITE_KEY=       # Cloudflare Turnstile site key
BETTER_AUTH_URL=          # Site URL (e.g., https://surbias.com)
ADMIN_EMAIL=              # Admin email for initial setup
KOFI_URL=                 # Override Ko-fi link (optional, defaults to ko-fi.com/surbias)

# Cron secret to protect /api/cron/* endpoints (when added)
CRON_SECRET=

# ============================================================
#  Infrastructure IDs (for deploy.sh)
# ============================================================
KV_NAMESPACE_ID=          # Cloudflare KV namespace ID for sessions
D1_DATABASE_ID=           # Cloudflare D1 database ID
